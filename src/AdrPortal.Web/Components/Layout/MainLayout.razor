@inherits LayoutComponentBase
@implements IDisposable
@inject RepositoryCatalogState RepositoryCatalogState
@inject IJSRuntime JSRuntime

<div class="shell">
    <header class="shell__header">
        <div class="brand">
            <span class="brand__dot" aria-hidden="true"></span>
            <span class="brand__name">ADR Portal</span>
        </div>
        <div class="shell__header-right">
            <span class="shell__status">Phase 13 source-to-target ADR comparison + import workflows</span>
            <button class="shell__theme-toggle"
                    type="button"
                    aria-label="@ThemeToggleAriaLabel"
                    aria-pressed="@IsDarkTheme"
                    title="@ThemeToggleAriaLabel"
                    @onclick="ToggleThemeAsync">
                <span class="shell__theme-toggle-icon" aria-hidden="true">@ThemeToggleIcon</span>
                <span class="shell__theme-toggle-text">@ThemeToggleText</span>
            </button>
        </div>
    </header>

    <div class="shell__body">
        <aside class="shell__sidebar">
            <nav class="shell__nav" aria-label="Primary navigation">
                <NavLink class="shell__nav-link" href="/" Match="NavLinkMatch.All">Overview</NavLink>
                <NavLink class="shell__nav-link shell__nav-link--with-badge" href="/global">
                    <span>Global library</span>
                    @if (RepositoryCatalogState.DashboardPendingCount > 0)
                    {
                        <span class="shell__nav-badge">@RepositoryCatalogState.DashboardPendingCount</span>
                    }
                </NavLink>
                <NavLink class="shell__nav-link" href="/compare">Compare repositories</NavLink>
                <NavLink class="shell__nav-link" href="/settings/repos">Repository settings</NavLink>
                <a class="shell__nav-link" href="/not-found">Workflow actions (coming soon)</a>
            </nav>

            <section class="shell__repositories" aria-label="Managed repositories">
                <h2 class="shell__repositories-title">Repositories</h2>
                @if (RepositoryCatalogState.Repositories.Count is 0)
                {
                    <p class="shell__hint">
                        No repositories configured yet.
                    </p>
                }
                else
                {
                    <ul class="shell__repo-list">
                        @foreach (var repository in RepositoryCatalogState.Repositories)
                        {
                            <li>
                                <NavLink class="shell__repo-item" href="@($"/repos/{repository.Id}")">
                                    <span class="shell__repo-item-head">
                                        <span class="shell__repo-name">@repository.DisplayName</span>
                                        @if (repository.IsActive)
                                        {
                                            <span class="shell__repo-indicator">Active</span>
                                        }
                                    </span>
                                    <span class="shell__repo-meta">@repository.RootPath</span>
                                </NavLink>
                            </li>
                        }
                    </ul>

                    <a class="shell__repo-manage" href="/settings/repos">Manage repositories · /settings/repos</a>
                }
            </section>
        </aside>

        <main class="shell__content" role="main">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code
{
    private const string LightThemeName = "light";
    private const string DarkThemeName = "dark";
    private string _theme = LightThemeName;

    private bool IsDarkTheme => string.Equals(_theme, DarkThemeName, StringComparison.Ordinal);

    private string ThemeToggleAriaLabel => IsDarkTheme
        ? "Dark mode enabled. Activate to switch to light mode."
        : "Light mode enabled. Activate to switch to dark mode.";

    private string ThemeToggleIcon => IsDarkTheme ? "☾" : "☀";

    private string ThemeToggleText => IsDarkTheme ? "Dark" : "Light";

    /// <summary>
    /// Subscribes to repository list updates and loads initial data.
    /// </summary>
    /// <returns>An asynchronous operation.</returns>
    protected override async Task OnInitializedAsync()
    {
        RepositoryCatalogState.Changed += HandleRepositoryCatalogChanged;
        await RepositoryCatalogState.RefreshAsync(CancellationToken.None);
    }

    /// <summary>
    /// Synchronizes the toggle state with the active theme after the first interactive render.
    /// </summary>
    /// <param name="firstRender">Whether the component is rendering for the first time.</param>
    /// <returns>An asynchronous operation.</returns>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _theme = await JSRuntime.InvokeAsync<string>("adrTheme.resolveInitialTheme");
        StateHasChanged();
    }

    /// <summary>
    /// Releases event subscriptions owned by the layout.
    /// </summary>
    public void Dispose()
    {
        RepositoryCatalogState.Changed -= HandleRepositoryCatalogChanged;
    }

    /// <summary>
    /// Switches between light and dark themes and persists the explicit user preference.
    /// </summary>
    /// <returns>An asynchronous operation.</returns>
    private async Task ToggleThemeAsync()
    {
        _theme = await JSRuntime.InvokeAsync<string>("adrTheme.toggleTheme", _theme);
    }

    /// <summary>
    /// Refreshes layout rendering when repository list changes.
    /// </summary>
    private void HandleRepositoryCatalogChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }
}
