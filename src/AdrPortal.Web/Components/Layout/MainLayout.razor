@inherits LayoutComponentBase

<div class="shell">
    <header class="shell__header">
        <div class="brand">
            <span class="brand__dot" aria-hidden="true"></span>
            <span class="brand__name">ADR Portal</span>
        </div>
        <span class="shell__status">Phase 1 scaffold</span>
    </header>

    <div class="shell__body">
        <aside class="shell__sidebar">
            <nav class="shell__nav" aria-label="Primary navigation">
                <a class="shell__nav-link" href="/">Overview</a>
                <a class="shell__nav-link" href="/not-found">Repository management (coming soon)</a>
                <a class="shell__nav-link" href="/not-found">ADR workflows (coming soon)</a>
            </nav>
            <p class="shell__hint">
                Core platform pieces are now in place. Feature pages and workflows are added in later phases.
            </p>
        </aside>

        <main class="shell__content" role="main">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
