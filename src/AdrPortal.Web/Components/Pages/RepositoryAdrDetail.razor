@page "/repos/{RepositoryId:int}/adr/{Number:int}"
@inject AdrDocumentService AdrDocumentService
@inject AdrListViewService AdrListViewService
@inject IAdrMarkdownRenderer AdrMarkdownRenderer
@inject GlobalLibraryService GlobalLibraryService
@inject AdrAiAssistantService AdrAiAssistantService
@using AdrPortal.Core.Entities
@using AdrPortal.Core.Ai
@using AdrPortal.Web.Services

<PageTitle>@GetPageTitle()</PageTitle>

@if (!string.IsNullOrWhiteSpace(loadError))
{
    <section class="panel adr-page">
        <h1>ADR detail</h1>
        <p class="repo-status repo-status--error">@loadError</p>
        <a class="inline-link" href="@($"/repos/{RepositoryId}")">Return to ADR list</a>
    </section>
}
else if (repository is null || detail is null)
{
    <section class="panel adr-page">
        <h1>ADR detail</h1>
        <p class="shell__hint">Loading ADR…</p>
    </section>
}
else
{
    <section class="panel adr-page">
        <header class="adr-page__header">
            <div>
                <p class="eyebrow">Repository ADR detail</p>
                <h1>@repository.DisplayName</h1>
                <p class="lead">ADR-@detail.Number.ToString("0000") from <code>@detail.RepoRelativePath</code>.</p>
            </div>
            <div class="adr-page__actions">
                <a class="adr-page__settings-link" href="@($"/repos/{RepositoryId}/adr/{detail.Number}/edit")">Edit ADR</a>
                <a class="adr-page__settings-link" href="@($"/repos/{RepositoryId}")">Back to list</a>
            </div>
        </header>
        <div class="adr-page__actions adr-page__actions--analysis">
            <button type="button"
                    class="adr-detail__button adr-detail__button--analysis"
                    @onclick="AnalyzeAffectedAdrsAsync"
                    disabled="@isAnalyzingAffectedAdrs">
                @(isAnalyzingAffectedAdrs ? "Analyzing affected ADRs..." : "Find Affected ADRs")
            </button>
        </div>
    </section>

    <article class="panel adr-detail">
        <header class="adr-detail__header">
            <div>
                <h2>ADR-@detail.Number.ToString("0000"): @detail.Title</h2>
                <p class="adr-detail__subtitle">@detail.Date.ToString("yyyy-MM-dd") · @detail.Slug</p>
            </div>
            <span class="state-badge @detail.StatusView.CssModifier">@detail.StatusView.Label</span>
        </header>

        @if (!string.IsNullOrWhiteSpace(transitionMessage))
        {
            <p class="@(transitionIsError ? "repo-status repo-status--error" : "repo-status")">@transitionMessage</p>
        }

        @if (!string.IsNullOrWhiteSpace(affectedAdrsMessage))
        {
            <p class="@(affectedAdrsIsError ? "repo-status repo-status--error" : "repo-status")">@affectedAdrsMessage</p>
        }

        <section class="adr-detail__meta">
            <div class="adr-detail__meta-item">
                <p>Status</p>
                <strong>@detail.StatusView.Label</strong>
            </div>
            <div class="adr-detail__meta-item">
                <p>Date</p>
                <strong>@detail.Date.ToString("yyyy-MM-dd")</strong>
            </div>
            <div class="adr-detail__meta-item">
                <p>Decision makers</p>
                <strong>@FormatPeople(detail.DecisionMakers)</strong>
            </div>
            <div class="adr-detail__meta-item">
                <p>Consulted</p>
                <strong>@FormatPeople(detail.Consulted)</strong>
            </div>
            <div class="adr-detail__meta-item">
                <p>Informed</p>
                <strong>@FormatPeople(detail.Informed)</strong>
            </div>
            <div class="adr-detail__meta-item">
                <p>Global template</p>
                <strong>@GetGlobalTemplateText(detail)</strong>
            </div>
            @if (syncStatus is not null)
            {
                <div class="adr-detail__meta-item">
                    <p>Sync status</p>
                    <strong>@GetSyncStatusText(syncStatus)</strong>
                </div>
            }
        </section>

        @if (detail.Status is AdrStatus.Proposed or AdrStatus.Accepted)
        {
            <section class="adr-detail__transitions">
                <h3>Lifecycle actions</h3>

                @if (detail.Status is AdrStatus.Proposed)
                {
                    <div class="adr-detail__transition-row">
                        <button type="button"
                                class="adr-detail__button adr-detail__button--accept"
                                @onclick="() => ApplyTransitionAsync(AdrTransitionAction.Accept)"
                                disabled="@isApplyingTransition">
                            Accept ADR
                        </button>
                        <button type="button"
                                class="adr-detail__button adr-detail__button--reject"
                                @onclick="() => ApplyTransitionAsync(AdrTransitionAction.Reject)"
                                disabled="@isApplyingTransition">
                            Reject ADR
                        </button>
                    </div>
                }
                else if (detail.Status is AdrStatus.Accepted)
                {
                    <div class="adr-detail__transition-row">
                        <label for="supersede-target">Superseded by ADR number</label>
                        <InputNumber id="supersede-target"
                                     class="adr-detail__supersede-input"
                                     @bind-Value="supersedeTargetNumber" />
                        <button type="button"
                                class="adr-detail__button adr-detail__button--supersede"
                                @onclick="() => ApplyTransitionAsync(AdrTransitionAction.Supersede)"
                                disabled="@isApplyingTransition">
                            Mark superseded
                        </button>
                    </div>
                    <div class="adr-detail__transition-row">
                        <button type="button"
                                class="adr-detail__button adr-detail__button--deprecate"
                                @onclick="() => ApplyTransitionAsync(AdrTransitionAction.Deprecate)"
                                disabled="@isApplyingTransition">
                            Mark deprecated
                        </button>
                    </div>
                }
            </section>
        }

        @if (syncStatus is not null)
        {
            <section class="adr-detail__sync">
                <h3>Global sync</h3>
                <p class="adr-detail__sync-summary">
                    Base template v@syncStatus.BaseTemplateVersion · Current global v@syncStatus.CurrentGlobalVersion
                </p>
                <ul class="adr-detail__sync-steps">
                    <li>Repo → library: use <strong>Propose library update</strong> when this ADR has template improvements.</li>
                    <li>Library → repos: open <a class="inline-link" href="@($"/global/{syncStatus.GlobalId}")">global detail</a> to apply or customise updates.</li>
                    <li>Run <strong>Find Affected ADRs</strong> after major changes to discover related decisions.</li>
                </ul>
                @if (!string.IsNullOrWhiteSpace(syncMessage))
                {
                    <p class="@(syncIsError ? "repo-status repo-status--error" : "repo-status")">@syncMessage</p>
                }
                @if (syncStatus.HasLocalChanges)
                {
                    <div class="adr-detail__transition-row">
                        <button type="button"
                                class="adr-detail__button adr-detail__button--propose"
                                @onclick="ProposeLibraryUpdateAsync"
                                disabled="@isApplyingSync || syncStatus.HasPendingProposal">
                            @(syncStatus.HasPendingProposal ? "Proposal pending" : "Propose library update")
                        </button>
                    </div>
                }
                else
                {
                    <p class="shell__hint">No local template divergence detected for repo → library proposals.</p>
                }

                @if (syncStatus.UpdateAvailable)
                {
                    <p class="repo-status">
                        A newer global template version is available. Review per-instance update options under
                        <a class="inline-link" href="@($"/global/{syncStatus.GlobalId}")">/global/@syncStatus.GlobalId</a>.
                    </p>
                }
            </section>
        }

        @if (detail.SupersededByNumber is int supersededByNumber)
        {
            <p class="repo-status">
                This ADR is superseded by ADR-@supersededByNumber.ToString("0000").
            </p>
        }

        @if (affectedAdrsResult is not null)
        {
            <section class="adr-detail__affected">
                <h3>Affected ADRs</h3>
                <p class="adr-detail__affected-summary">@affectedAdrsResult.Summary</p>
                @if (affectedAdrsResult.IsFallback)
                {
                    <p class="adr-detail__affected-fallback">
                        Deterministic fallback active
                        @if (!string.IsNullOrWhiteSpace(affectedAdrsResult.FallbackReason))
                        {
                            <span>· @affectedAdrsResult.FallbackReason</span>
                        }
                    </p>
                }
                @if (affectedAdrsResult.Items.Count is 0)
                {
                    <p class="shell__hint">No related ADRs were identified.</p>
                }
                else
                {
                    <ul class="adr-detail__affected-list">
                        @foreach (var item in affectedAdrsResult.Items)
                        {
                            <li>
                                <div>
                                    <strong>ADR-@item.AdrNumber.ToString("0000"): @item.Title</strong>
                                    <p>@item.Rationale</p>
                                    @if (item.Signals.Count > 0)
                                    {
                                        <p class="adr-detail__affected-signals"><strong>Signals:</strong> @string.Join(", ", item.Signals)</p>
                                    }
                                </div>
                                <span class="state-badge @GetImpactBadgeCssModifier(item.ImpactLevel)">@item.ImpactLevel</span>
                            </li>
                        }
                    </ul>
                }
            </section>
        }

        <section class="adr-detail__content">
            @((MarkupString)detail.HtmlContent)
        </section>
    </article>
}

@code
{
    [Parameter]
    public int RepositoryId { get; set; }

    [Parameter]
    public int Number { get; set; }

    private ManagedRepository? repository;
    private AdrDetailViewModel? detail;
    private string? loadError;
    private string? transitionMessage;
    private bool transitionIsError;
    private bool isApplyingTransition;
    private int? supersedeTargetNumber;
    private RepositoryAdrSyncStatus? syncStatus;
    private string? syncMessage;
    private bool syncIsError;
    private bool isApplyingSync;
    private AffectedAdrAnalysisResult? affectedAdrsResult;
    private string? affectedAdrsMessage;
    private bool affectedAdrsIsError;
    private bool isAnalyzingAffectedAdrs;

    /// <summary>
    /// Loads repository and ADR detail values for the requested route.
    /// </summary>
    /// <returns>An asynchronous operation.</returns>
    protected override async Task OnParametersSetAsync()
    {
        loadError = null;
        repository = null;
        detail = null;
        transitionMessage = null;
        transitionIsError = false;
        isApplyingTransition = false;
        supersedeTargetNumber = null;
        syncStatus = null;
        syncMessage = null;
        syncIsError = false;
        isApplyingSync = false;
        affectedAdrsResult = null;
        affectedAdrsMessage = null;
        affectedAdrsIsError = false;
        isAnalyzingAffectedAdrs = false;

        try
        {
            var result = await AdrDocumentService.GetRepositoryAdrAsync(RepositoryId, Number, CancellationToken.None);
            if (result is null)
            {
                loadError = $"ADR-{Number:0000} was not found for repository '{RepositoryId}'.";
                return;
            }

            repository = result.Value.Repository;
            detail = AdrListViewService.BuildDetail(result.Value.Adr, AdrMarkdownRenderer.Render(result.Value.Adr.RawMarkdown));
            supersedeTargetNumber = detail.SupersededByNumber;
            syncStatus = await GlobalLibraryService.GetRepositoryAdrSyncStatusAsync(RepositoryId, result.Value.Adr, CancellationToken.None);
            await LoadAffectedAdrsAnalysisAsync();
        }
        catch (InvalidOperationException exception)
        {
            loadError = exception.Message;
        }
        catch (ArgumentException exception)
        {
            loadError = exception.Message;
        }
        catch (FormatException exception)
        {
            loadError = exception.Message;
        }
        catch (IOException exception)
        {
            loadError = exception.Message;
        }
    }

    /// <summary>
    /// Applies a lifecycle transition and refreshes detail state.
    /// </summary>
    /// <param name="action">Transition action to execute.</param>
    /// <returns>An asynchronous operation.</returns>
    private async Task ApplyTransitionAsync(AdrTransitionAction action)
    {
        if (detail is null || isApplyingTransition)
        {
            return;
        }

        transitionMessage = null;
        transitionIsError = false;
        isApplyingTransition = true;

        try
        {
            var transitionResult = await AdrDocumentService.TransitionAdrAsync(
                RepositoryId,
                Number,
                action,
                supersedeTargetNumber,
                CancellationToken.None);

            if (transitionResult is null)
            {
                transitionIsError = true;
                transitionMessage = $"ADR-{Number:0000} was not found for repository '{RepositoryId}'.";
                return;
            }

            repository = transitionResult.Repository;
            detail = AdrListViewService.BuildDetail(
                transitionResult.Adr,
                AdrMarkdownRenderer.Render(transitionResult.Adr.RawMarkdown));
            supersedeTargetNumber = detail.SupersededByNumber;
            transitionMessage = transitionResult.Message;
            syncStatus = await GlobalLibraryService.GetRepositoryAdrSyncStatusAsync(RepositoryId, transitionResult.Adr, CancellationToken.None);
            await LoadAffectedAdrsAnalysisAsync();
        }
        catch (InvalidOperationException exception)
        {
            transitionIsError = true;
            transitionMessage = exception.Message;
        }
        catch (ArgumentException exception)
        {
            transitionIsError = true;
            transitionMessage = exception.Message;
        }
        catch (FormatException exception)
        {
            transitionIsError = true;
            transitionMessage = exception.Message;
        }
        catch (IOException exception)
        {
            transitionIsError = true;
            transitionMessage = exception.Message;
        }
        finally
        {
            isApplyingTransition = false;
        }
    }

    /// <summary>
    /// Proposes a global library update from the current repository ADR.
    /// </summary>
    /// <returns>An asynchronous operation.</returns>
    private async Task ProposeLibraryUpdateAsync()
    {
        if (detail is null || isApplyingSync || syncStatus is null)
        {
            return;
        }

        isApplyingSync = true;
        syncMessage = null;
        syncIsError = false;

        try
        {
            var adrResult = await AdrDocumentService.GetRepositoryAdrAsync(RepositoryId, Number, CancellationToken.None);
            if (adrResult is null)
            {
                syncIsError = true;
                syncMessage = $"ADR-{Number:0000} was not found for repository '{RepositoryId}'.";
                return;
            }

            var result = await GlobalLibraryService.ProposeLibraryUpdateAsync(RepositoryId, adrResult.Value.Adr, CancellationToken.None);
            syncMessage = result.Message;
            syncStatus = await GlobalLibraryService.GetRepositoryAdrSyncStatusAsync(RepositoryId, adrResult.Value.Adr, CancellationToken.None);
        }
        catch (InvalidOperationException exception)
        {
            syncIsError = true;
            syncMessage = exception.Message;
        }
        catch (ArgumentException exception)
        {
            syncIsError = true;
            syncMessage = exception.Message;
        }
        catch (FormatException exception)
        {
            syncIsError = true;
            syncMessage = exception.Message;
        }
        catch (IOException exception)
        {
            syncIsError = true;
            syncMessage = exception.Message;
        }
        finally
        {
            isApplyingSync = false;
        }
    }

    /// <summary>
    /// Runs affected ADR analysis explicitly from the detail page action.
    /// </summary>
    /// <returns>An asynchronous operation.</returns>
    private async Task AnalyzeAffectedAdrsAsync()
    {
        if (isAnalyzingAffectedAdrs)
        {
            return;
        }

        await LoadAffectedAdrsAnalysisAsync();
    }

    /// <summary>
    /// Loads affected ADR analysis for the current detail context.
    /// </summary>
    /// <returns>An asynchronous operation.</returns>
    private async Task LoadAffectedAdrsAnalysisAsync()
    {
        if (detail is null || isAnalyzingAffectedAdrs)
        {
            return;
        }

        isAnalyzingAffectedAdrs = true;
        affectedAdrsMessage = null;
        affectedAdrsIsError = false;

        try
        {
            var analysis = await AdrAiAssistantService.FindAffectedAdrsAsync(RepositoryId, detail.Number, CancellationToken.None);
            if (analysis is null)
            {
                affectedAdrsResult = null;
                affectedAdrsIsError = true;
                affectedAdrsMessage = $"Unable to analyze ADR-{detail.Number:0000} for repository '{RepositoryId}'.";
                return;
            }

            affectedAdrsResult = analysis;
            affectedAdrsMessage = $"Affected ADR analysis complete ({analysis.Items.Count} item(s)).";
        }
        catch (InvalidOperationException exception)
        {
            affectedAdrsResult = null;
            affectedAdrsIsError = true;
            affectedAdrsMessage = exception.Message;
        }
        catch (ArgumentException exception)
        {
            affectedAdrsResult = null;
            affectedAdrsIsError = true;
            affectedAdrsMessage = exception.Message;
        }
        catch (FormatException exception)
        {
            affectedAdrsResult = null;
            affectedAdrsIsError = true;
            affectedAdrsMessage = exception.Message;
        }
        catch (IOException exception)
        {
            affectedAdrsResult = null;
            affectedAdrsIsError = true;
            affectedAdrsMessage = exception.Message;
        }
        finally
        {
            isAnalyzingAffectedAdrs = false;
        }
    }

    /// <summary>
    /// Formats a list of people for compact metadata display.
    /// </summary>
    /// <param name="values">Input values.</param>
    /// <returns>Display text.</returns>
    private static string FormatPeople(IReadOnlyList<string> values)
    {
        return values.Count is 0 ? "—" : string.Join(", ", values);
    }

    /// <summary>
    /// Formats global template metadata text.
    /// </summary>
    /// <param name="viewModel">Detail view model.</param>
    /// <returns>Display text for global template metadata.</returns>
    private static string GetGlobalTemplateText(AdrDetailViewModel viewModel)
    {
        if (viewModel.GlobalId is null || viewModel.GlobalVersion is null)
        {
            return "Not linked";
        }

        return $"{viewModel.GlobalId} · v{viewModel.GlobalVersion}";
    }

    /// <summary>
    /// Formats sync status text for metadata.
    /// </summary>
    /// <param name="status">Sync status projection.</param>
    /// <returns>Sync summary text.</returns>
    private static string GetSyncStatusText(RepositoryAdrSyncStatus status)
    {
        if (status.HasLocalChanges && status.UpdateAvailable)
        {
            return "Has local changes · update available";
        }

        if (status.HasLocalChanges)
        {
            return "Has local changes";
        }

        if (status.UpdateAvailable)
        {
            return "Update available";
        }

        return "In sync";
    }

    /// <summary>
    /// Gets badge CSS modifier for affected ADR impact level.
    /// </summary>
    /// <param name="impactLevel">Impact level value.</param>
    /// <returns>Badge modifier CSS class.</returns>
    private static string GetImpactBadgeCssModifier(AdrImpactLevel impactLevel)
    {
        return impactLevel switch
        {
            AdrImpactLevel.High => "impact-high",
            AdrImpactLevel.Medium => "impact-medium",
            _ => "impact-low"
        };
    }

    /// <summary>
    /// Gets the page title for metadata.
    /// </summary>
    /// <returns>Page title text.</returns>
    private string GetPageTitle()
    {
        return detail is null ? $"ADR-{Number:0000}" : $"ADR-{detail.Number:0000} {detail.Title}";
    }
}
