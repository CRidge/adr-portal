@page "/Error"
@using System.Diagnostics

<PageTitle>Error</PageTitle>

<section class="panel">
<h1>Unexpected error</h1>
<p class="lead">An unhandled error occurred while processing your request.</p>

@if (ShowRequestId)
{
    <p><strong>Request ID:</strong> <code>@RequestId</code></p>
}

<h2>Development mode</h2>
<p>Swapping to <strong>Development</strong> shows detailed diagnostics for local troubleshooting.</p>
<p>
    <strong>Do not enable Development in production</strong> because detailed exception information can expose sensitive data.
</p>
</section>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
