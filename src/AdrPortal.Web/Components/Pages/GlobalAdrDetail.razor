@page "/global/{GlobalId:guid}"
@inject GlobalLibraryService GlobalLibraryService
@inject AdrQuestionDomainService AdrQuestionDomainService

<PageTitle>@GetPageTitle()</PageTitle>

@if (!string.IsNullOrWhiteSpace(loadError))
{
    <section class="panel global-adr-page">
        <h1>Global ADR detail</h1>
        <p class="repo-status repo-status--error">@loadError</p>
        <a class="inline-link" href="/global">Return to global library</a>
    </section>
}
else if (detail is null)
{
    <section class="panel global-adr-page">
        <h1>Global ADR detail</h1>
        <p class="shell__hint">Loading global ADR details…</p>
    </section>
}
else
{
    <section class="panel global-adr-page">
        <header class="global-adr-page__header">
            <div>
                <p class="eyebrow">Global ADR template</p>
                <h1>@detail.Title</h1>
                <p class="lead">
                    Global ID <code>@detail.GlobalId</code> · current version <strong>@($"v{detail.CurrentVersion}")</strong>
                </p>
            </div>
            <div class="global-adr-page__actions">
                <a class="global-adr-page__link" href="/global">Back to global library</a>
            </div>
        </header>
        <div class="global-adr-page__stats">
            <span><strong>Pending proposals:</strong> @detail.PendingProposalCount</span>
            <span><strong>Update available:</strong> @detail.UpdateAvailableCount</span>
            <span><strong>Instances:</strong> @detail.Instances.Count</span>
        </div>
    </section>

    <section class="panel global-adr-panel">
        <header class="global-adr-panel__header">
            <h2>Add ADR question</h2>
            <small>Guidance-only generation</small>
        </header>
        <p class="global-adr-panel__help">
            Ask a question to draft a repository proposal for this global ADR. Existing global versions are used as guidance only.
            The draft is created as a pending <strong>Repo → library proposal</strong> for manual review.
        </p>
        <div class="global-adr-question">
            <label class="global-adr-question__label" for="global-adr-question">Question prompt</label>
            <textarea id="global-adr-question"
                      class="global-adr-question__input"
                      @bind="globalQuestionPrompt"
                      @bind:event="oninput"
                      placeholder="Example: What unit test framework should we recommend for .NET repositories?"></textarea>
        </div>
        <div class="global-adr-question__actions">
            <button type="button"
                    class="global-adr-button global-adr-button--review"
                    @onclick="GenerateGlobalQuestionProposalAsync"
                    disabled="@isGeneratingGlobalQuestionDraft">
                @(isGeneratingGlobalQuestionDraft ? "Generating proposal…" : "Generate proposal")
            </button>
        </div>
        @if (!string.IsNullOrWhiteSpace(globalQuestionMessage))
        {
            <p class="@(globalQuestionError ? "repo-status repo-status--error" : "repo-status")">@globalQuestionMessage</p>
        }
        @if (globalQuestionResult is not null)
        {
            <section class="global-adr-question-result">
                <h3>Generated recommendation</h3>
                <p><strong>Suggested option:</strong> @globalQuestionResult.SuggestedOption</p>
                <p>@globalQuestionResult.SuggestedOptionRationale</p>
                <p class="global-adr-question-result__fit">@globalQuestionResult.Recommendation.DecisionFit</p>
                @if (globalQuestionResult.Recommendation.IsFallback)
                {
                    <p class="global-adr-question-result__fallback">
                        Deterministic fallback active
                        @if (!string.IsNullOrWhiteSpace(globalQuestionResult.Recommendation.FallbackReason))
                        {
                            <span>· @globalQuestionResult.Recommendation.FallbackReason</span>
                        }
                    </p>
                }
                @if (globalQuestionResult.ConsideredOptions.Count > 0)
                {
                    <div class="global-adr-question-result__section">
                        <h4>Options with pros and cons</h4>
                        <ul>
                            @foreach (var option in globalQuestionResult.ConsideredOptions)
                            {
                                <li>
                                    <strong>@option.Name</strong>
                                    <p>@option.Summary</p>
                                    @if (option.Pros.Count > 0)
                                    {
                                        <p><strong>Pros</strong></p>
                                        <ul class="global-adr-question-result__sublist">
                                            @foreach (var pro in option.Pros)
                                            {
                                                <li>@pro</li>
                                            }
                                        </ul>
                                    }
                                    @if (option.Cons.Count > 0)
                                    {
                                        <p><strong>Cons</strong></p>
                                        <ul class="global-adr-question-result__sublist">
                                            @foreach (var con in option.Cons)
                                            {
                                                <li>@con</li>
                                            }
                                        </ul>
                                    }
                                </li>
                            }
                        </ul>
                    </div>
                }
            </section>
            <section class="global-adr-next-step">
                <h4>Next step: review and decide</h4>
                <ol>
                    <li>Open <strong>Repo → library proposals</strong> for this global ADR.</li>
                    <li>Select <strong>Review draft</strong> to inspect the generated markdown.</li>
                    <li>Choose <strong>Accept</strong> to publish a new global version, or <strong>Discard</strong> to reject.</li>
                </ol>
                <div class="global-adr-next-step__actions">
                    <a class="global-adr-page__link global-adr-page__link--cta" href="#repo-library-proposals">
                        Go to pending proposals
                    </a>
                </div>
            </section>
        }
    </section>

    <section class="panel global-adr-panel">
        <header class="global-adr-panel__header">
            <h2>Version history</h2>
            <small>@detail.Versions.Count version(s)</small>
        </header>
        @if (detail.Versions.Count is 0)
        {
            <p class="global-adr-panel__empty">No versions registered yet.</p>
        }
        else
        {
            <ul class="global-adr-versions" role="list">
                @foreach (var version in detail.Versions)
                {
                    <li class="global-adr-versions__row">
                        <div>
                            <strong>@($"v{version.VersionNumber}") · @version.Title</strong>
                            <span>@version.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm 'UTC'")</span>
                        </div>
                        <details>
                            <summary>View markdown</summary>
                            <pre>@version.MarkdownContent</pre>
                        </details>
                    </li>
                }
            </ul>
        }
    </section>

    <section class="panel global-adr-panel">
        <header class="global-adr-panel__header">
            <h2 id="repo-library-proposals">Repo → library proposals</h2>
            <small>@detail.PendingProposalCount pending</small>
        </header>
        <p class="global-adr-panel__help">
            Review repository-authored template changes here. Use <strong>Review draft</strong> to inspect markdown,
            then accept to publish a new global version or discard when the change is repository-specific.
        </p>
        @if (!string.IsNullOrWhiteSpace(proposalMessage))
        {
            <p class="@(proposalError ? "repo-status repo-status--error" : "repo-status")">@proposalMessage</p>
        }
        @if (detail.Proposals.Count is 0)
        {
            <p class="global-adr-panel__empty">No proposals have been submitted for this global ADR.</p>
        }
        else
        {
            <table class="global-adr-table">
                <thead>
                    <tr>
                        <th scope="col">Repository ADR</th>
                        <th scope="col">From version</th>
                        <th scope="col">State</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var proposal in detail.Proposals)
                    {
                        var isDraftPreviewVisible = expandedProposalIds.Contains(proposal.Id);
                        var isQuestionProposal = proposal.LocalAdrNumber == 0;
                        <tr>
                            <td>
                                <strong>
                                    @if (isQuestionProposal)
                                    {
                                        @($"{proposal.RepositoryDisplayName} · Question proposal")
                                    }
                                    else
                                    {
                                        @($"{proposal.RepositoryDisplayName} · ADR-{proposal.LocalAdrNumber:0000}")
                                    }
                                </strong>
                                <div class="global-adr-table__meta">@proposal.ProposedTitle</div>
                                <div class="global-adr-table__meta">Created @proposal.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm 'UTC'")</div>
                                @if (isQuestionProposal)
                                {
                                    <div class="global-adr-flags">
                                        <span class="global-adr-flag global-adr-flag--question">Question-generated</span>
                                    </div>
                                }
                            </td>
                            <td>@($"v{proposal.ProposedFromVersion}")</td>
                            <td>@(proposal.IsPending ? "Pending" : "Reviewed")</td>
                            <td>
                                <div class="global-adr-table__actions">
                                    <button type="button" class="global-adr-button global-adr-button--review" @onclick="() => ToggleProposalPreview(proposal.Id)">
                                        @(isDraftPreviewVisible ? "Hide draft" : "Review draft")
                                    </button>
                                    @if (proposal.IsPending)
                                    {
                                        <button type="button" class="global-adr-button global-adr-button--accept" @onclick="() => AcceptProposalAsync(proposal.Id)" disabled="@isApplyingProposal">
                                            Accept
                                        </button>
                                        <button type="button" class="global-adr-button global-adr-button--reject" @onclick="() => DiscardProposalAsync(proposal.Id)" disabled="@isApplyingProposal">
                                            Discard
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="shell__hint">No actions</span>
                                    }
                                </div>
                            </td>
                        </tr>
                        @if (isDraftPreviewVisible)
                        {
                            <tr class="global-adr-table__preview-row">
                                <td colspan="4">
                                    <div class="global-adr-table__preview">
                                        <p class="global-adr-table__meta"><strong>Draft markdown preview</strong></p>
                                        <pre>@proposal.ProposedMarkdownContent</pre>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        }
    </section>

    <section class="panel global-adr-panel">
        <header class="global-adr-panel__header">
            <h2>Baseline diff viewer</h2>
            <small>@($"v{(detail.Versions.Count > 1 ? detail.Versions[1].VersionNumber : 0)} → v{(detail.Versions.Count > 0 ? detail.Versions[0].VersionNumber : 0)}")</small>
        </header>
        <pre class="global-adr-diff">@detail.BaselineDiff</pre>
    </section>

    <section class="panel global-adr-panel">
        <header class="global-adr-panel__header">
            <h2>Library → repos instances</h2>
            <small>@detail.UpdateAvailableCount update available</small>
        </header>
        <p class="global-adr-panel__help">
            Roll out global template updates to linked repository ADRs. Apply for direct update, customise when local edits are needed, or dismiss to defer.
        </p>
        @if (!string.IsNullOrWhiteSpace(instanceMessage))
        {
            <p class="@(instanceError ? "repo-status repo-status--error" : "repo-status")">@instanceMessage</p>
        }
        @if (detail.Instances.Count is 0)
        {
            <p class="global-adr-panel__empty">No repository instances are linked to this global ADR.</p>
        }
        else
        {
            <table class="global-adr-table">
                <thead>
                    <tr>
                        <th scope="col">Repository ADR</th>
                        <th scope="col">Status</th>
                        <th scope="col">Base version</th>
                        <th scope="col">Flags</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var instance in detail.Instances)
                    {
                        <tr>
                            <td>
                                <a class="inline-link" href="@($"/repos/{instance.RepositoryId}/adr/{instance.LocalAdrNumber}")">
                                    @instance.RepositoryDisplayName · ADR-@instance.LocalAdrNumber.ToString("0000")
                                </a>
                                <div class="global-adr-table__meta">@instance.RepoRelativePath</div>
                            </td>
                            <td>
                                <span class="state-badge @instance.LastKnownStatusView.CssModifier">
                                    @instance.LastKnownStatusView.Label
                                </span>
                            </td>
                            <td>@($"v{instance.BaseTemplateVersion}")</td>
                            <td>
                                <div class="global-adr-flags">
                                    @if (instance.HasLocalChanges)
                                    {
                                        <span class="global-adr-flag global-adr-flag--local">HasLocalChanges</span>
                                    }
                                    @if (instance.UpdateAvailable)
                                    {
                                        <span class="global-adr-flag global-adr-flag--update">UpdateAvailable</span>
                                    }
                                    @if (!instance.HasLocalChanges && !instance.UpdateAvailable)
                                    {
                                        <span class="global-adr-flag">In sync</span>
                                    }
                                </div>
                            </td>
                            <td>
                                <div class="global-adr-table__actions">
                                    <button type="button" class="global-adr-button global-adr-button--review" @onclick="() => ApplyInstanceUpdateAsync(instance.Id)" disabled="@isApplyingInstance">
                                        Apply
                                    </button>
                                    <button type="button" class="global-adr-button global-adr-button--customise" @onclick="() => CustomiseInstanceUpdateAsync(instance.Id)" disabled="@isApplyingInstance">
                                        Customise
                                    </button>
                                    <button type="button" class="global-adr-button" @onclick="() => DismissInstanceUpdateAsync(instance.Id)" disabled="@isApplyingInstance">
                                        Dismiss
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
}

@code
{
    [Parameter]
    public Guid GlobalId { get; set; }

    private GlobalAdrDetailProjection? detail;
    private string? loadError;
    private string? proposalMessage;
    private bool proposalError;
    private bool isApplyingProposal;
    private string globalQuestionPrompt = string.Empty;
    private string? globalQuestionMessage;
    private bool globalQuestionError;
    private bool isGeneratingGlobalQuestionDraft;
    private AdrQuestionDraftResult? globalQuestionResult;
    private string? instanceMessage;
    private bool instanceError;
    private bool isApplyingInstance;
    private readonly HashSet<int> expandedProposalIds = [];

    /// <summary>
    /// Loads global ADR detail projection.
    /// </summary>
    /// <returns>An asynchronous operation.</returns>
    protected override async Task OnParametersSetAsync()
    {
        loadError = null;
        detail = null;
        proposalMessage = null;
        proposalError = false;
        isApplyingProposal = false;
        globalQuestionPrompt = string.Empty;
        globalQuestionMessage = null;
        globalQuestionError = false;
        isGeneratingGlobalQuestionDraft = false;
        globalQuestionResult = null;
        instanceMessage = null;
        instanceError = false;
        isApplyingInstance = false;
        expandedProposalIds.Clear();

        try
        {
            detail = await GlobalLibraryService.GetDetailAsync(GlobalId, CancellationToken.None);
            if (detail is null)
            {
                loadError = $"Global ADR '{GlobalId}' was not found.";
            }
        }
        catch (InvalidOperationException exception)
        {
            loadError = exception.Message;
        }
        catch (ArgumentException exception)
        {
            loadError = exception.Message;
        }
        catch (FormatException exception)
        {
            loadError = exception.Message;
        }
        catch (IOException exception)
        {
            loadError = exception.Message;
        }
    }

    /// <summary>
    /// Generates a guidance-only ADR proposal from a global-library question prompt.
    /// </summary>
    /// <returns>An asynchronous operation.</returns>
    private async Task GenerateGlobalQuestionProposalAsync()
    {
        if (isGeneratingGlobalQuestionDraft || detail is null)
        {
            return;
        }

        var trimmedQuestion = globalQuestionPrompt.Trim();
        if (string.IsNullOrWhiteSpace(trimmedQuestion))
        {
            globalQuestionError = true;
            globalQuestionMessage = "Enter a question prompt before generating a proposal.";
            return;
        }

        isGeneratingGlobalQuestionDraft = true;
        globalQuestionError = false;
        globalQuestionMessage = null;
        globalQuestionResult = null;

        try
        {
            var generated = await AdrQuestionDomainService.GenerateForGlobalLibraryAsync(
                GlobalId,
                trimmedQuestion,
                CancellationToken.None);
            if (generated is null)
            {
                globalQuestionError = true;
                globalQuestionMessage = $"Global ADR '{GlobalId}' was not found.";
                return;
            }

            _ = await GlobalLibraryService.AddQuestionProposalAsync(
                GlobalId,
                generated.Title,
                generated.DraftMarkdownBody,
                CancellationToken.None);

            globalQuestionResult = generated;
            globalQuestionPrompt = string.Empty;
            globalQuestionError = false;
            globalQuestionMessage = "Draft created. Review it under Repo → library proposals, then accept or discard.";
            detail = await GlobalLibraryService.GetDetailAsync(GlobalId, CancellationToken.None);
            var generatedQuestionProposal = detail?.Proposals.FirstOrDefault(
                proposal => proposal.IsPending && proposal.LocalAdrNumber == 0);
            if (generatedQuestionProposal is not null)
            {
                _ = expandedProposalIds.Add(generatedQuestionProposal.Id);
            }
        }
        catch (InvalidOperationException exception)
        {
            globalQuestionError = true;
            globalQuestionMessage = exception.Message;
        }
        catch (ArgumentException exception)
        {
            globalQuestionError = true;
            globalQuestionMessage = exception.Message;
        }
        catch (FormatException exception)
        {
            globalQuestionError = true;
            globalQuestionMessage = exception.Message;
        }
        catch (IOException exception)
        {
            globalQuestionError = true;
            globalQuestionMessage = exception.Message;
        }
        finally
        {
            isGeneratingGlobalQuestionDraft = false;
        }
    }

    /// <summary>
    /// Accepts a pending library update proposal.
    /// </summary>
    /// <param name="proposalId">Proposal identifier.</param>
    /// <returns>An asynchronous operation.</returns>
    private async Task AcceptProposalAsync(int proposalId)
    {
        if (isApplyingProposal)
        {
            return;
        }

        isApplyingProposal = true;
        proposalMessage = null;
        proposalError = false;

        try
        {
            var result = await GlobalLibraryService.AcceptLibraryProposalAsync(GlobalId, proposalId, CancellationToken.None);
            proposalMessage = result.Message;
            detail = await GlobalLibraryService.GetDetailAsync(GlobalId, CancellationToken.None);
        }
        catch (InvalidOperationException exception)
        {
            proposalError = true;
            proposalMessage = exception.Message;
        }
        catch (ArgumentException exception)
        {
            proposalError = true;
            proposalMessage = exception.Message;
        }
        catch (FormatException exception)
        {
            proposalError = true;
            proposalMessage = exception.Message;
        }
        catch (IOException exception)
        {
            proposalError = true;
            proposalMessage = exception.Message;
        }
        finally
        {
            isApplyingProposal = false;
        }
    }

    /// <summary>
    /// Discards a pending library update proposal.
    /// </summary>
    /// <param name="proposalId">Proposal identifier.</param>
    /// <returns>An asynchronous operation.</returns>
    private async Task DiscardProposalAsync(int proposalId)
    {
        if (isApplyingProposal)
        {
            return;
        }

        isApplyingProposal = true;
        proposalMessage = null;
        proposalError = false;

        try
        {
            var result = await GlobalLibraryService.DiscardLibraryProposalAsync(GlobalId, proposalId, CancellationToken.None);
            proposalMessage = result.Message;
            detail = await GlobalLibraryService.GetDetailAsync(GlobalId, CancellationToken.None);
        }
        catch (InvalidOperationException exception)
        {
            proposalError = true;
            proposalMessage = exception.Message;
        }
        catch (ArgumentException exception)
        {
            proposalError = true;
            proposalMessage = exception.Message;
        }
        catch (FormatException exception)
        {
            proposalError = true;
            proposalMessage = exception.Message;
        }
        catch (IOException exception)
        {
            proposalError = true;
            proposalMessage = exception.Message;
        }
        finally
        {
            isApplyingProposal = false;
        }
    }

    /// <summary>
    /// Applies template updates for one repository instance.
    /// </summary>
    /// <param name="instanceId">Instance identifier.</param>
    /// <returns>An asynchronous operation.</returns>
    private async Task ApplyInstanceUpdateAsync(int instanceId)
    {
        await RunInstanceActionAsync(() => GlobalLibraryService.ApplyUpdateToInstanceAsync(GlobalId, instanceId, CancellationToken.None));
    }

    /// <summary>
    /// Marks one repository instance as custom updated.
    /// </summary>
    /// <param name="instanceId">Instance identifier.</param>
    /// <returns>An asynchronous operation.</returns>
    private async Task CustomiseInstanceUpdateAsync(int instanceId)
    {
        await RunInstanceActionAsync(() => GlobalLibraryService.CustomiseInstanceUpdateAsync(GlobalId, instanceId, CancellationToken.None));
    }

    /// <summary>
    /// Dismisses update notification for one instance.
    /// </summary>
    /// <param name="instanceId">Instance identifier.</param>
    /// <returns>An asynchronous operation.</returns>
    private async Task DismissInstanceUpdateAsync(int instanceId)
    {
        await RunInstanceActionAsync(() => GlobalLibraryService.DismissInstanceUpdateAsync(GlobalId, instanceId, CancellationToken.None));
    }

    /// <summary>
    /// Runs one instance-level action with shared status handling.
    /// </summary>
    /// <param name="action">Action to execute.</param>
    /// <returns>An asynchronous operation.</returns>
    private async Task RunInstanceActionAsync(Func<Task<GlobalSyncActionResult>> action)
    {
        if (isApplyingInstance)
        {
            return;
        }

        isApplyingInstance = true;
        instanceMessage = null;
        instanceError = false;
        try
        {
            var result = await action();
            instanceMessage = result.Message;
            detail = await GlobalLibraryService.GetDetailAsync(GlobalId, CancellationToken.None);
        }
        catch (InvalidOperationException exception)
        {
            instanceError = true;
            instanceMessage = exception.Message;
        }
        catch (ArgumentException exception)
        {
            instanceError = true;
            instanceMessage = exception.Message;
        }
        catch (FormatException exception)
        {
            instanceError = true;
            instanceMessage = exception.Message;
        }
        catch (IOException exception)
        {
            instanceError = true;
            instanceMessage = exception.Message;
        }
        finally
        {
            isApplyingInstance = false;
        }
    }

    /// <summary>
    /// Toggles proposal markdown preview visibility for one proposal row.
    /// </summary>
    /// <param name="proposalId">Proposal identifier.</param>
    private void ToggleProposalPreview(int proposalId)
    {
        if (!expandedProposalIds.Add(proposalId))
        {
            _ = expandedProposalIds.Remove(proposalId);
        }
    }

    /// <summary>
    /// Gets the page title text.
    /// </summary>
    /// <returns>Page title.</returns>
    private string GetPageTitle()
    {
        return detail is null ? "Global ADR detail" : $"{detail.Title} · Global ADR";
    }
}
