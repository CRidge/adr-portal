@page "/repos/{RepositoryId:int}/adr/new"
@page "/repos/{RepositoryId:int}/adr/{Number:int}/edit"
@inject AdrDocumentService AdrDocumentService
@inject AdrAiAssistantService AdrAiAssistantService
@using AdrPortal.Core.Entities
@using AdrPortal.Core.Ai
@using AdrPortal.Web.Services

<PageTitle>@GetPageTitle()</PageTitle>

@if (!string.IsNullOrWhiteSpace(loadError))
{
    <section class="panel adr-editor-page">
        <h1>@GetHeading()</h1>
        <p class="repo-status repo-status--error">@loadError</p>
        <a class="inline-link" href="@($"/repos/{RepositoryId}")">Return to ADR list</a>
    </section>
}
else if (repository is null || editContext is null)
{
    <section class="panel adr-editor-page">
        <h1>@GetHeading()</h1>
        <p class="shell__hint">Loading editor…</p>
    </section>
}
else
{
    <section class="panel adr-editor-page">
        <header class="adr-editor-page__header">
            <div>
                <p class="eyebrow">Repository ADR editor</p>
                <h1>@repository.DisplayName</h1>
                <p class="lead">@GetLeadText()</p>
            </div>
            <div class="adr-editor-page__actions">
                <a class="adr-editor-page__link" href="@($"/repos/{RepositoryId}")">Back to list</a>
                @if (!isCreateMode && Number is int numberValue)
                {
                    <a class="adr-editor-page__link" href="@($"/repos/{RepositoryId}/adr/{numberValue}")">View ADR</a>
                }
            </div>
        </header>

        <div class="adr-editor-page__context">
            <span><strong>Path:</strong> @repository.RootPath</span>
            <span><strong>ADR folder:</strong> /@repository.AdrFolder.Replace('\\', '/')</span>
            <span><strong>Status:</strong> @GetStatusBadgeText()</span>
        </div>
    </section>

    <section class="panel adr-editor">
        @if (!string.IsNullOrWhiteSpace(statusMessage))
        {
            <p class="@GetStatusClass()">@statusMessage</p>
        }

        <EditForm EditContext="editContext" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <fieldset class="adr-editor__fieldset">
                <legend class="adr-editor__legend">MADR metadata</legend>

                <div class="adr-editor__grid adr-editor__grid--three">
                    <div class="adr-editor__field">
                        <label class="adr-editor__label" for="adr-title">Title</label>
                        <InputText id="adr-title" class="adr-editor__input" @bind-Value="editorModel.Title" />
                        <ValidationMessage For="() => editorModel.Title" />
                    </div>

                    <div class="adr-editor__field">
                        <label class="adr-editor__label" for="adr-slug">Slug</label>
                        <InputText id="adr-slug" class="adr-editor__input" @bind-Value="editorModel.Slug" />
                        <ValidationMessage For="() => editorModel.Slug" />
                    </div>

                    <div class="adr-editor__field">
                        <label class="adr-editor__label" for="adr-date">Decision date</label>
                        <InputDate id="adr-date" class="adr-editor__input" @bind-Value="editorModel.Date" />
                        <ValidationMessage For="() => editorModel.Date" />
                    </div>
                </div>

                <div class="adr-editor__grid adr-editor__grid--two">
                    <div class="adr-editor__field">
                        <label class="adr-editor__label" for="adr-status">Status</label>
                        <InputSelect id="adr-status" class="adr-editor__input" @bind-Value="editorModel.Status">
                            @foreach (var status in editableStatuses)
                            {
                                <option value="@status">@status</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="() => editorModel.Status" />
                    </div>

                    <div class="adr-editor__field">
                        <label class="adr-editor__label" for="adr-superseded-by">Superseded by ADR (optional)</label>
                        <InputNumber id="adr-superseded-by" class="adr-editor__input" @bind-Value="editorModel.SupersededByNumber" />
                        <ValidationMessage For="() => editorModel.SupersededByNumber" />
                    </div>
                </div>

                <div class="adr-editor__grid adr-editor__grid--three">
                    <div class="adr-editor__field">
                        <label class="adr-editor__label" for="adr-decision-makers">Decision makers</label>
                        <InputTextArea id="adr-decision-makers" class="adr-editor__textarea adr-editor__textarea--small" @bind-Value="editorModel.DecisionMakersText" />
                        <ValidationMessage For="() => editorModel.DecisionMakersText" />
                    </div>

                    <div class="adr-editor__field">
                        <label class="adr-editor__label" for="adr-consulted">Consulted</label>
                        <InputTextArea id="adr-consulted" class="adr-editor__textarea adr-editor__textarea--small" @bind-Value="editorModel.ConsultedText" />
                        <ValidationMessage For="() => editorModel.ConsultedText" />
                    </div>

                    <div class="adr-editor__field">
                        <label class="adr-editor__label" for="adr-informed">Informed</label>
                        <InputTextArea id="adr-informed" class="adr-editor__textarea adr-editor__textarea--small" @bind-Value="editorModel.InformedText" />
                        <ValidationMessage For="() => editorModel.InformedText" />
                    </div>
                </div>
            </fieldset>

            <fieldset class="adr-editor__fieldset">
                <legend class="adr-editor__legend">MADR markdown body</legend>
                <p class="adr-editor__hint">
                    Provide markdown only. Raw HTML is not accepted for safety. Include context, decision drivers, options, and consequences.
                </p>
                <InputTextArea id="adr-markdown-body"
                               class="adr-editor__textarea adr-editor__textarea--body"
                               @bind-Value="editorModel.MarkdownBody" />
                <ValidationMessage For="() => editorModel.MarkdownBody" />
            </fieldset>

            <div class="adr-editor__actions">
                <button type="submit" class="adr-editor__button adr-editor__button--primary" disabled="@isSaving">
                    @GetSaveButtonLabel()
                </button>
                <button type="button" class="adr-editor__button" @onclick="ResetAsync" disabled="@isSaving">
                    Reset
                </button>
                <button type="button"
                        class="adr-editor__button adr-editor__button--analysis"
                        @onclick="EvaluateAndRecommendAsync"
                        disabled="@(isSaving || isEvaluatingRecommendation || editContext is null)">
                    @(isEvaluatingRecommendation ? "Evaluating..." : "Evaluate ADR draft")
                </button>
                <button type="button"
                        class="adr-editor__button adr-editor__button--manual"
                        @onclick="InsertManualEvaluationScaffoldAsync"
                        disabled="@(isSaving || isEvaluatingRecommendation || editContext is null)">
                    Insert manual evaluation scaffold
                </button>
                <button type="button"
                        class="adr-editor__button adr-editor__button--manual"
                        @onclick="InsertManualEvaluationScaffoldAsync"
                        disabled="@(isSaving || isEvaluatingRecommendation || editContext is null)">
                    Insert manual evaluation scaffold
                </button>
            </div>
            <p class="adr-editor__hint">
                Tip: run AI evaluation after writing options/pros/cons, then save and use ADR detail to manage lifecycle and global sync.
            </p>
        </EditForm>

        @if (!string.IsNullOrWhiteSpace(recommendationMessage))
        {
            <p class="@(recommendationIsError ? "repo-status repo-status--error" : "repo-status")">@recommendationMessage</p>
        }

        @if (recommendation is not null)
        {
            <section class="adr-editor-ai">
                <h3>AI recommendation</h3>
                <p><strong>Preferred option:</strong> @recommendation.PreferredOption</p>
                <p>@recommendation.RecommendationSummary</p>
                <p class="adr-editor-ai__fit">@recommendation.DecisionFit</p>
                <div class="adr-editor-ai__actions">
                    <button type="button"
                            class="adr-editor__button adr-editor__button--analysis"
                            @onclick="ApplyRecommendationToDraftAsync"
                            disabled="@(isSaving || isEvaluatingRecommendation || editContext is null)">
                        Apply recommendation to draft body
                    </button>
                </div>
                @if (recommendation.IsFallback)
                {
                    <p class="adr-editor-ai__fallback">
                        Deterministic fallback active
                        @if (!string.IsNullOrWhiteSpace(recommendation.FallbackReason))
                        {
                            <span>· @recommendation.FallbackReason</span>
                        }
                    </p>
                }
                @if (recommendation.Options.Count > 0)
                {
                    <div class="adr-editor-ai__section">
                        <h4>Ranked options</h4>
                        <ul>
                            @foreach (var option in recommendation.Options)
                            {
                                <li>
                                    <strong>@option.OptionName</strong>
                                    <span> (score @option.Score.ToString("0.00"))</span>
                                    <p class="adr-editor-ai__option-summary">@option.Summary</p>
                                    <p>@option.Rationale</p>
                                    @if (option.Pros.Count > 0)
                                    {
                                        <p><strong>Pros</strong></p>
                                        <ul class="adr-editor-ai__sublist">
                                            @foreach (var pro in option.Pros)
                                            {
                                                <li>@pro</li>
                                            }
                                        </ul>
                                    }
                                    @if (option.Cons.Count > 0)
                                    {
                                        <p><strong>Cons</strong></p>
                                        <ul class="adr-editor-ai__sublist">
                                            @foreach (var con in option.Cons)
                                            {
                                                <li>@con</li>
                                            }
                                        </ul>
                                    }
                                </li>
                            }
                        </ul>
                    </div>
                }
                @if (recommendation.Risks.Count > 0)
                {
                    <div class="adr-editor-ai__section">
                        <h4>Risks</h4>
                        <ul>
                            @foreach (var risk in recommendation.Risks)
                            {
                                <li>@risk</li>
                            }
                        </ul>
                    </div>
                }
                @if (recommendation.SuggestedAlternatives.Count > 0)
                {
                    <div class="adr-editor-ai__section">
                        <h4>Suggested alternatives</h4>
                        <ul>
                            @foreach (var alternative in recommendation.SuggestedAlternatives)
                            {
                                <li>@alternative</li>
                            }
                        </ul>
                    </div>
                }
            </section>
        }

        @if (ShouldShowManualFallbackPath())
        {
            <section class="adr-editor-manual">
                <h3>Manual evaluation path</h3>
                <p>
                    AI guidance is unavailable or running in deterministic fallback mode. You can still complete this ADR manually:
                </p>
                <ol>
                    <li>Capture at least three options in <strong>Considered Options</strong>.</li>
                    <li>Add explicit <strong>Pros</strong> and <strong>Cons</strong> per option.</li>
                    <li>Record the chosen option and rationale under <strong>Decision Outcome</strong>.</li>
                    <li>List risks and expected consequences under <strong>Consequences</strong>.</li>
                </ol>
                <button type="button"
                        class="adr-editor__button adr-editor__button--manual"
                        @onclick="InsertManualEvaluationScaffoldAsync"
                        disabled="@(isSaving || isEvaluatingRecommendation || editContext is null)">
                    Insert manual scaffold into markdown body
                </button>
            </section>
        }
    </section>
}

@code
{
    private static readonly IReadOnlyList<AdrStatus> editableStatuses =
    [
        AdrStatus.Proposed,
        AdrStatus.Accepted,
        AdrStatus.Rejected,
        AdrStatus.Superseded,
        AdrStatus.Deprecated
    ];

    [Parameter]
    public int RepositoryId { get; set; }

    [Parameter]
    public int? Number { get; set; }

    private ManagedRepository? repository;
    private AdrEditorModel editorModel = AdrEditorModel.CreateForNew();
    private AdrEditorModel initialModel = AdrEditorModel.CreateForNew();
    private EditContext? editContext;
    private bool isSaving;
    private bool isCreateMode;
    private string? loadError;
    private string? statusMessage;
    private bool statusIsError;
    private AdrEvaluationRecommendation? recommendation;
    private string? recommendationMessage;
    private bool recommendationIsError;
    private bool isEvaluatingRecommendation;

    /// <summary>
    /// Loads repository and ADR values required by create/edit routes.
    /// </summary>
    /// <returns>An asynchronous operation.</returns>
    protected override async Task OnParametersSetAsync()
    {
        loadError = null;
        statusMessage = null;
        statusIsError = false;
        repository = null;
        editContext = null;
        isSaving = false;
        isCreateMode = !Number.HasValue;
        recommendation = null;
        recommendationMessage = null;
        recommendationIsError = false;
        isEvaluatingRecommendation = false;

        try
        {
            if (isCreateMode)
            {
                var createResult = await AdrDocumentService.GetRepositoryForCreateAsync(RepositoryId, CancellationToken.None);
                if (createResult is null)
                {
                    loadError = $"Repository '{RepositoryId}' was not found.";
                    return;
                }

                repository = createResult.Value.Repository;
                editorModel = AdrEditorModel.CreateForNew();
                editorModel.Slug = $"adr-{createResult.Value.NextNumber:0000}";
                initialModel = editorModel.Clone();
                editContext = new EditContext(editorModel);
                return;
            }

            var detailResult = await AdrDocumentService.GetRepositoryAdrAsync(RepositoryId, Number!.Value, CancellationToken.None);
            if (detailResult is null)
            {
                loadError = $"ADR-{Number:0000} was not found for repository '{RepositoryId}'.";
                return;
            }

            repository = detailResult.Value.Repository;
            editorModel = AdrEditorModel.FromAdr(detailResult.Value.Adr);
            initialModel = editorModel.Clone();
            editContext = new EditContext(editorModel);
        }
        catch (InvalidOperationException exception)
        {
            loadError = exception.Message;
        }
        catch (ArgumentException exception)
        {
            loadError = exception.Message;
        }
        catch (FormatException exception)
        {
            loadError = exception.Message;
        }
        catch (IOException exception)
        {
            loadError = exception.Message;
        }
    }

    /// <summary>
    /// Persists current form values through the repository layer.
    /// </summary>
    /// <returns>An asynchronous operation.</returns>
    private async Task SaveAsync()
    {
        if (isSaving || repository is null)
        {
            return;
        }

        isSaving = true;
        statusMessage = null;
        statusIsError = false;
        recommendation = null;
        recommendationMessage = null;
        recommendationIsError = false;

        try
        {
            AdrPersistResult? persistResult = isCreateMode
                ? await AdrDocumentService.CreateAdrAsync(RepositoryId, editorModel.ToInput(), CancellationToken.None)
                : await AdrDocumentService.UpdateAdrAsync(RepositoryId, Number!.Value, editorModel.ToInput(), CancellationToken.None);

            if (persistResult is null)
            {
                statusIsError = true;
                statusMessage = isCreateMode
                    ? "Unable to create ADR because the repository no longer exists."
                    : "Unable to save ADR because it no longer exists.";
                return;
            }

            repository = persistResult.Repository;
            editorModel = AdrEditorModel.FromAdr(persistResult.Adr);
            initialModel = editorModel.Clone();
            editContext = new EditContext(editorModel);
            Number = persistResult.Adr.Number;
            isCreateMode = false;
            statusMessage = $"Saved ADR-{persistResult.Adr.Number:0000}.";
        }
        catch (InvalidOperationException exception)
        {
            statusIsError = true;
            statusMessage = exception.Message;
        }
        catch (ArgumentException exception)
        {
            statusIsError = true;
            statusMessage = exception.Message;
        }
        catch (FormatException exception)
        {
            statusIsError = true;
            statusMessage = exception.Message;
        }
        catch (IOException exception)
        {
            statusIsError = true;
            statusMessage = exception.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    /// <summary>
    /// Restores the editor model back to loaded defaults.
    /// </summary>
    /// <returns>An asynchronous operation.</returns>
    private Task ResetAsync()
    {
        if (isSaving)
        {
            return Task.CompletedTask;
        }

        editorModel = initialModel.Clone();
        editContext = new EditContext(editorModel);
        statusMessage = "Editor reset to loaded values.";
        statusIsError = false;
        recommendation = null;
        recommendationMessage = null;
        recommendationIsError = false;
        return Task.CompletedTask;
    }

    /// <summary>
    /// Runs AI recommendation analysis for the current draft values.
    /// </summary>
    /// <returns>An asynchronous operation.</returns>
    private async Task EvaluateAndRecommendAsync()
    {
        if (isSaving || isEvaluatingRecommendation || editContext is null)
        {
            return;
        }

        recommendation = null;
        recommendationMessage = null;
        recommendationIsError = false;

        var isValid = editContext.Validate();
        if (!isValid)
        {
            recommendationIsError = true;
            recommendationMessage = "Fix validation errors before running AI evaluation.";
            return;
        }

        isEvaluatingRecommendation = true;
        try
        {
            var result = await AdrAiAssistantService.EvaluateAndRecommendAsync(
                RepositoryId,
                Number,
                editorModel.ToInput(),
                CancellationToken.None);

            if (result is null)
            {
                recommendationIsError = true;
                recommendationMessage = $"Repository '{RepositoryId}' was not found.";
                return;
            }

            recommendation = result;
            recommendationMessage = "AI recommendation generated.";
        }
        catch (InvalidOperationException exception)
        {
            recommendationIsError = true;
            recommendationMessage = exception.Message;
        }
        catch (ArgumentException exception)
        {
            recommendationIsError = true;
            recommendationMessage = exception.Message;
        }
        catch (FormatException exception)
        {
            recommendationIsError = true;
            recommendationMessage = exception.Message;
        }
        catch (IOException exception)
        {
            recommendationIsError = true;
            recommendationMessage = exception.Message;
        }
        catch (Exception exception)
        {
            recommendationIsError = true;
            recommendationMessage = $"Unable to generate AI recommendation. {exception.Message} Use the manual evaluation scaffold to continue.";
        }
        finally
        {
            isEvaluatingRecommendation = false;
        }
    }

    /// <summary>
    /// Applies current recommendation details into the markdown body sections.
    /// </summary>
    /// <returns>An asynchronous operation.</returns>
    private Task ApplyRecommendationToDraftAsync()
    {
        if (editContext is null || recommendation is null || isSaving || isEvaluatingRecommendation)
        {
            return Task.CompletedTask;
        }

        var updatedMarkdown = BuildMarkdownWithRecommendation(editorModel.MarkdownBody, recommendation);
        editorModel.MarkdownBody = updatedMarkdown;
        editContext.NotifyFieldChanged(new FieldIdentifier(editorModel, nameof(AdrEditorModel.MarkdownBody)));
        recommendationMessage = "Applied recommendation content to markdown body. Review and adjust before saving.";
        recommendationIsError = false;
        return Task.CompletedTask;
    }

    /// <summary>
    /// Inserts a manual evaluation scaffold in markdown body for non-AI workflows.
    /// </summary>
    /// <returns>An asynchronous operation.</returns>
    private Task InsertManualEvaluationScaffoldAsync()
    {
        if (editContext is null || isSaving || isEvaluatingRecommendation)
        {
            return Task.CompletedTask;
        }

        editorModel.MarkdownBody = BuildMarkdownWithManualScaffold(editorModel.MarkdownBody);
        editContext.NotifyFieldChanged(new FieldIdentifier(editorModel, nameof(AdrEditorModel.MarkdownBody)));
        recommendation = null;
        recommendationIsError = false;
        recommendationMessage = "Inserted manual evaluation scaffold. Complete options, pros/cons, recommendation, and risks.";
        return Task.CompletedTask;
    }

    /// <summary>
    /// Gets whether manual fallback instructions should be shown.
    /// </summary>
    /// <returns><see langword="true"/> when manual path should be rendered; otherwise <see langword="false"/>.</returns>
    private bool ShouldShowManualFallbackPath()
    {
        if (recommendation is not null && recommendation.IsFallback)
        {
            return true;
        }

        if (recommendationIsError && !string.IsNullOrWhiteSpace(recommendationMessage))
        {
            return true;
        }

        return false;
    }

    /// <summary>
    /// Builds markdown with manual scaffold details.
    /// </summary>
    /// <param name="currentMarkdown">Current markdown body.</param>
    /// <returns>Markdown body containing manual evaluation scaffold sections.</returns>
    private static string BuildMarkdownWithManualScaffold(string currentMarkdown)
    {
        var normalized = NormalizeMarkdown(currentMarkdown);
        var consideredOptionsContent = """
        - Option A
          - Pros:
            - 
          - Cons:
            - 
        - Option B
          - Pros:
            - 
          - Cons:
            - 
        - Option C
          - Pros:
            - 
          - Cons:
            - 
        """;
        var decisionOutcomeContent = """
        Chosen option: 
        
        Rationale:
        - 
        
        Rejected alternatives:
        - 
        """;
        var consequencesContent = """
        - Positive:
          - 
        - Negative:
          - 
        - Risks and mitigations:
          - Risk: 
            Mitigation: 
        """;

        normalized = UpsertSection(normalized, "## Considered Options", consideredOptionsContent);
        normalized = UpsertSection(normalized, "## Decision Outcome", decisionOutcomeContent);
        normalized = UpsertSection(normalized, "### Consequences", consequencesContent);
        return normalized;
    }

    /// <summary>
    /// Builds markdown with recommendation details populated into core ADR sections.
    /// </summary>
    /// <param name="currentMarkdown">Current markdown body.</param>
    /// <param name="analysis">Recommendation analysis payload.</param>
    /// <returns>Markdown with recommendation content inserted.</returns>
    private static string BuildMarkdownWithRecommendation(
        string currentMarkdown,
        AdrEvaluationRecommendation analysis)
    {
        var normalized = NormalizeMarkdown(currentMarkdown);
        var consideredOptionsContent = BuildConsideredOptionsContent(analysis);
        var decisionOutcomeContent = BuildDecisionOutcomeContent(analysis);
        var consequencesContent = BuildConsequencesContent(analysis);

        normalized = UpsertSection(normalized, "## Considered Options", consideredOptionsContent);
        normalized = UpsertSection(normalized, "## Decision Outcome", decisionOutcomeContent);
        normalized = UpsertSection(normalized, "### Consequences", consequencesContent);
        return normalized;
    }

    /// <summary>
    /// Formats considered options markdown from recommendation options.
    /// </summary>
    /// <param name="analysis">Recommendation analysis payload.</param>
    /// <returns>Markdown section content.</returns>
    private static string BuildConsideredOptionsContent(AdrEvaluationRecommendation analysis)
    {
        if (analysis.Options.Count is 0)
        {
            return "- No options were generated. Add options manually.";
        }

        var builder = new System.Text.StringBuilder();
        foreach (var option in analysis.Options)
        {
            builder.AppendLine($"- {option.OptionName} (score {option.Score:0.00})");
            builder.AppendLine($"  - Summary: {option.Summary}");
            if (option.Pros.Count > 0)
            {
                builder.AppendLine("  - Pros:");
                foreach (var pro in option.Pros)
                {
                    builder.AppendLine($"    - {pro}");
                }
            }

            if (option.Cons.Count > 0)
            {
                builder.AppendLine("  - Cons:");
                foreach (var con in option.Cons)
                {
                    builder.AppendLine($"    - {con}");
                }
            }

            builder.AppendLine($"  - Evaluation notes: {option.Rationale}");
        }

        return builder.ToString().TrimEnd();
    }

    /// <summary>
    /// Formats decision outcome markdown from recommendation summary.
    /// </summary>
    /// <param name="analysis">Recommendation analysis payload.</param>
    /// <returns>Markdown section content.</returns>
    private static string BuildDecisionOutcomeContent(AdrEvaluationRecommendation analysis)
    {
        var builder = new System.Text.StringBuilder();
        builder.AppendLine($"Chosen option: {analysis.PreferredOption}");
        builder.AppendLine();
        builder.AppendLine($"Rationale: {analysis.RecommendationSummary}");
        builder.AppendLine();
        builder.AppendLine($"Decision fit: {analysis.DecisionFit}");
        if (analysis.IsFallback)
        {
            builder.AppendLine();
            var fallbackReason = string.IsNullOrWhiteSpace(analysis.FallbackReason)
                ? "AI fallback mode was used."
                : analysis.FallbackReason.Trim();
            builder.AppendLine($"Fallback note: {fallbackReason}");
        }

        if (analysis.SuggestedAlternatives.Count > 0)
        {
            builder.AppendLine();
            builder.AppendLine("Rejected alternatives:");
            foreach (var alternative in analysis.SuggestedAlternatives)
            {
                builder.AppendLine($"- {alternative}");
            }
        }

        return builder.ToString().TrimEnd();
    }

    /// <summary>
    /// Formats consequences markdown from recommendation risks.
    /// </summary>
    /// <param name="analysis">Recommendation analysis payload.</param>
    /// <returns>Markdown section content.</returns>
    private static string BuildConsequencesContent(AdrEvaluationRecommendation analysis)
    {
        var builder = new System.Text.StringBuilder();
        builder.AppendLine("- Positive:");
        builder.AppendLine($"  - Expected alignment with selected option '{analysis.PreferredOption}'.");
        builder.AppendLine("- Negative:");
        builder.AppendLine("  - Additional implementation and verification effort is required.");
        builder.AppendLine("- Risks and mitigations:");
        if (analysis.Risks.Count is 0)
        {
            builder.AppendLine("  - Risk: No explicit AI risks identified.");
            builder.AppendLine("    Mitigation: Perform manual architecture review before accepting.");
        }
        else
        {
            foreach (var risk in analysis.Risks)
            {
                builder.AppendLine($"  - Risk: {risk}");
                builder.AppendLine("    Mitigation: Validate this risk in architecture review and capture owner/date.");
            }
        }

        return builder.ToString().TrimEnd();
    }

    /// <summary>
    /// Inserts or replaces markdown section content.
    /// </summary>
    /// <param name="markdown">Current markdown body.</param>
    /// <param name="heading">Section heading text.</param>
    /// <param name="content">Replacement content.</param>
    /// <returns>Updated markdown body.</returns>
    private static string UpsertSection(string markdown, string heading, string content)
    {
        var normalized = NormalizeMarkdown(markdown);
        var lines = normalized.Split('\n');
        var headingLine = heading.Trim();
        var startIndex = Array.FindIndex(
            lines,
            line => string.Equals(line.Trim(), headingLine, StringComparison.OrdinalIgnoreCase));

        if (startIndex < 0)
        {
            return AppendSection(normalized, headingLine, content);
        }

        var endIndex = lines.Length;
        for (var index = startIndex + 1; index < lines.Length; index++)
        {
            var candidate = lines[index].Trim();
            if (candidate.StartsWith("## ", StringComparison.Ordinal)
                || candidate.StartsWith("### ", StringComparison.Ordinal))
            {
                endIndex = index;
                break;
            }
        }

        var builder = new System.Text.StringBuilder();
        for (var index = 0; index <= startIndex; index++)
        {
            builder.AppendLine(lines[index]);
        }

        builder.AppendLine();
        builder.AppendLine(content.Trim());
        builder.AppendLine();
        for (var index = endIndex; index < lines.Length; index++)
        {
            builder.AppendLine(lines[index]);
        }

        return NormalizeMarkdown(builder.ToString());
    }

    /// <summary>
    /// Appends a markdown section at the end of body content.
    /// </summary>
    /// <param name="markdown">Current markdown body.</param>
    /// <param name="heading">Section heading text.</param>
    /// <param name="content">Section content.</param>
    /// <returns>Updated markdown body.</returns>
    private static string AppendSection(string markdown, string heading, string content)
    {
        var builder = new System.Text.StringBuilder(markdown.Trim());
        if (builder.Length > 0)
        {
            builder.AppendLine();
            builder.AppendLine();
        }

        builder.AppendLine(heading);
        builder.AppendLine();
        builder.AppendLine(content.Trim());
        return NormalizeMarkdown(builder.ToString());
    }

    /// <summary>
    /// Normalizes markdown line endings and trims outer whitespace.
    /// </summary>
    /// <param name="markdown">Markdown content.</param>
    /// <returns>Normalized markdown body.</returns>
    private static string NormalizeMarkdown(string markdown)
    {
        if (string.IsNullOrWhiteSpace(markdown))
        {
            return string.Empty;
        }

        return markdown
            .TrimStart('\uFEFF')
            .Replace("\r\n", "\n", StringComparison.Ordinal)
            .Replace('\r', '\n')
            .Trim();
    }

    /// <summary>
    /// Gets heading text for create or edit mode.
    /// </summary>
    /// <returns>Heading text.</returns>
    private string GetHeading()
    {
        return isCreateMode ? "Create ADR" : "Edit ADR";
    }

    /// <summary>
    /// Gets lead text describing current route mode.
    /// </summary>
    /// <returns>Route-specific lead content.</returns>
    private string GetLeadText()
    {
        if (isCreateMode)
        {
            return "Create a new MADR file using required metadata and markdown sections.";
        }

        return Number is int numberValue
            ? $"Edit ADR-{numberValue:0000} metadata and markdown content."
            : "Edit ADR metadata and markdown content.";
    }

    /// <summary>
    /// Gets status badge text for page context.
    /// </summary>
    /// <returns>Route status text.</returns>
    private string GetStatusBadgeText()
    {
        return isCreateMode ? "Draft (new)" : editorModel.Status.ToString();
    }

    /// <summary>
    /// Gets status CSS class for informational or error message.
    /// </summary>
    /// <returns>CSS class for status message.</returns>
    private string GetStatusClass()
    {
        return statusIsError ? "repo-status repo-status--error" : "repo-status";
    }

    /// <summary>
    /// Gets save button label.
    /// </summary>
    /// <returns>Button text for current mode.</returns>
    private string GetSaveButtonLabel()
    {
        return isCreateMode ? "Create ADR" : "Save changes";
    }

    /// <summary>
    /// Gets page title text.
    /// </summary>
    /// <returns>Document title.</returns>
    private string GetPageTitle()
    {
        return isCreateMode
            ? "Create ADR"
            : Number is int numberValue ? $"Edit ADR-{numberValue:0000}" : "Edit ADR";
    }
