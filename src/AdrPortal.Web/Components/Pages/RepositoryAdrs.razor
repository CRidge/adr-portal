@page "/repos/{RepositoryId:int}"
@inject AiBootstrapService AiBootstrapService
@inject AdrDocumentService AdrDocumentService
@inject AdrListViewService AdrListViewService
@inject RepositoryInboxUploadService RepositoryInboxUploadService
@using AdrPortal.Core.Ai
@using AdrPortal.Core.Entities
@using AdrPortal.Web.Services

<PageTitle>@GetPageTitle()</PageTitle>

@if (!string.IsNullOrWhiteSpace(loadError))
{
    <section class="panel adr-page">
        <h1>ADR library</h1>
        <p class="repo-status repo-status--error">@loadError</p>
        <a class="inline-link" href="/settings/repos">Manage repositories</a>
    </section>
}
else if (repository is null)
{
    <section class="panel adr-page">
        <h1>ADR library</h1>
        <p class="shell__hint">Loading repository…</p>
    </section>
}
else
{
    <section class="panel adr-page">
        <header class="adr-page__header">
            <div>
                <p class="eyebrow">Repository ADRs</p>
                <h1>@repository.DisplayName</h1>
                <p class="lead">Browse architectural decisions from <code>@($"/{repository.AdrFolder}")</code> with status filters and search.</p>
            </div>
            <div class="adr-page__actions">
                <a class="adr-page__settings-link" href="@($"/repos/{RepositoryId}/adr/new")">+ New ADR</a>
                <a class="adr-page__settings-link" href="/settings/repos">Manage repositories</a>
            </div>
        </header>

        <div class="adr-page__context">
            <span><strong>Path:</strong> @repository.RootPath</span>
            <span><strong>ADR folder:</strong> /@repository.AdrFolder.Replace('\\', '/')</span>
            <span><strong>Total ADRs:</strong> @projection.AllItems.Count</span>
            @if (HasInboxConfigured())
            {
                <span><strong>Inbox:</strong> @GetInboxDisplayPath()</span>
            }
            else
            {
                <span><strong>Inbox:</strong> disabled</span>
            }
        </div>
    </section>

    <section class="panel adr-panel">
        <header class="adr-panel__header">
            <h2>ADR Library Snapshot</h2>
            <small>@projection.FilteredItems.Count result(s) shown</small>
        </header>

        <div class="adr-toolbar">
            <label class="adr-toolbar__search" for="adr-search-box">Search ADRs</label>
            <input id="adr-search-box"
                   class="adr-toolbar__input"
                   type="search"
                   value="@searchTerm"
                   @oninput="HandleSearchInput"
                   placeholder="Search by ADR number, title, slug, or status" />
        </div>

        <div class="adr-filter-row">
            <strong>Status filters</strong>
            <div class="adr-filter-row__chips">
                <button type="button"
                        class="chip @(selectedStatus is null ? "chip--selected" : string.Empty)"
                        @onclick="ClearStatusFilter">
                    All <span class="chip__count">@projection.AllItems.Count</span>
                </button>
                @foreach (var option in projection.FilterOptions)
                {
                    <button type="button"
                            class="chip @option.CssModifier @(selectedStatus == option.Status ? "chip--selected" : string.Empty)"
                            @onclick="() => ToggleStatusFilter(option.Status)">
                        @option.Label <span class="chip__count">@option.Count</span>
                    </button>
                }
            </div>
        </div>

        @if (projection.AllItems.Count is 0)
        {
            <div class="adr-bootstrap">
                <h3>Empty repository ADR library</h3>
                <p class="adr-bootstrap__lead">
                    Bootstrap ADR proposals directly from this repository codebase. The generated drafts stay in <span class="state-badge proposed">proposed</span>
                    status and queue Git/PR work for a later workflow phase.
                </p>

                @if (!string.IsNullOrWhiteSpace(bootstrapMessage))
                {
                    <p class="@GetBootstrapMessageCssClass()">@bootstrapMessage</p>
                }

                <button type="button"
                        class="adr-bootstrap__primary"
                        @onclick="GenerateBootstrapAsync"
                        disabled="@IsBootstrapActionBusy()">
                    @(isGeneratingProposals ? "Scanning codebase…" : "Bootstrap ADRs with AI")
                </button>

                @if (bootstrapProposalSet is not null)
                {
                    <div class="adr-bootstrap__summary">
                        <span><strong>Scanned files:</strong> @bootstrapProposalSet.ScannedFileCount</span>
                        <span><strong>Chunks:</strong> @bootstrapProposalSet.Chunks.Count</span>
                        <span><strong>Proposals:</strong> @bootstrapProposalSet.Proposals.Count</span>
                        <span><strong>Selected:</strong> @selectedProposalIds.Count</span>
                    </div>

                    @if (bootstrapProposalSet.Proposals.Count is 0)
                    {
                        <p class="adr-panel__empty">No bootstrap proposals were generated from the current repository content.</p>
                    }
                    else
                    {
                        <div class="adr-bootstrap__cards">
                            @foreach (var proposal in bootstrapProposalSet.Proposals)
                            {
                                var isSelected = selectedProposalIds.Contains(proposal.ProposalId);
                                <article class="adr-bootstrap-card @(isSelected ? "adr-bootstrap-card--selected" : string.Empty)">
                                    <header class="adr-bootstrap-card__header">
                                        <div>
                                            <h4>@proposal.Title</h4>
                                            <p><strong>Slug:</strong> @proposal.SuggestedSlug</p>
                                        </div>
                                        <button type="button"
                                                class="adr-bootstrap-card__select"
                                                @onclick="() => ToggleProposalSelection(proposal.ProposalId)"
                                                disabled="@IsBootstrapActionBusy()">
                                            @(isSelected ? "Selected" : "Select")
                                        </button>
                                    </header>
                                    <p class="adr-bootstrap-card__problem">@proposal.ProblemStatement</p>
                                    <p class="adr-bootstrap-card__meta"><strong>Confidence:</strong> @proposal.ConfidenceScore.ToString("0.00")</p>

                                    @if (proposal.InitialOptions.Count > 0)
                                    {
                                        <div class="adr-bootstrap-card__section">
                                            <strong>Initial options</strong>
                                            <ul>
                                                @foreach (var option in proposal.InitialOptions)
                                                {
                                                    <li>@option</li>
                                                }
                                            </ul>
                                        </div>
                                    }

                                    @if (proposal.EvidenceFiles.Count > 0)
                                    {
                                        <div class="adr-bootstrap-card__section">
                                            <strong>Evidence files</strong>
                                            <ul>
                                                @foreach (var file in proposal.EvidenceFiles)
                                                {
                                                    <li><code>@file</code></li>
                                                }
                                            </ul>
                                        </div>
                                    }
                                </article>
                            }
                        </div>

                        <div class="adr-bootstrap__actions">
                            <button type="button"
                                    class="adr-bootstrap__primary"
                                    @onclick="AcceptSelectedProposalsAsync"
                                    disabled="@(!CanAcceptSelectedProposals())">
                                @(isApplyingProposals ? "Writing ADR drafts…" : "Accept selected proposals")
                            </button>
                            <button type="button"
                                    class="adr-bootstrap__secondary"
                                    @onclick="SelectAllProposals"
                                    disabled="@IsBootstrapActionBusy()">
                                Select all
                            </button>
                            <button type="button"
                                    class="adr-bootstrap__secondary"
                                    @onclick="ClearSelection"
                                    disabled="@IsBootstrapActionBusy()">
                                Clear selection
                            </button>
                        </div>
                    }
                }
            </div>
        }
        else if (projection.FilteredItems.Count is 0)
        {
            <p class="adr-panel__empty">No ADRs match the active search and filter criteria.</p>
        }
        else
        {
            <ul class="adr-list" role="list">
                @foreach (var item in projection.FilteredItems)
                {
                    <li class="adr-row">
                        <a class="adr-row__title" href="@($"/repos/{RepositoryId}/adr/{item.Number}")">
                            <strong>ADR-@item.Number.ToString("0000") • @item.Title</strong>
                            <span>@item.Date.ToString("yyyy-MM-dd") · @item.Slug</span>
                        </a>
                        <div class="adr-row__actions">
                            <span class="state-badge @item.StatusView.CssModifier">@item.StatusView.Label</span>
                            <a class="adr-row__edit" href="@($"/repos/{RepositoryId}/adr/{item.Number}/edit")">Edit</a>
                        </div>
                    </li>
                }
            </ul>
        }

        @if (HasInboxConfigured())
        {
            <div class="adr-upload-zone">
                <h3>Inbox upload</h3>
                <p class="adr-upload-zone__hint">
                    Drag and drop .md files here or use browse. Uploaded files follow the same inbox import pipeline as file-system watcher intake.
                </p>
                <label class="adr-upload-zone__drop">
                    <span class="adr-upload-zone__drop-label">Drop markdown files here, or click to browse</span>
                    <InputFile class="adr-upload-zone__input" OnChange="HandleInboxUploadAsync" accept=".md,text/markdown" multiple />
                </label>
                @if (!string.IsNullOrWhiteSpace(uploadStatusMessage))
                {
                    <p class="@(uploadStatusIsError ? "repo-status repo-status--error" : "repo-status")">@uploadStatusMessage</p>
                }
            </div>
        }
    </section>
}

@code
{
    [Parameter]
    public int RepositoryId { get; set; }

    private ManagedRepository? repository;
    private IReadOnlyList<Adr> repositoryAdrs = [];
    private AdrListProjectionResult projection = new()
    {
        AllItems = [],
        FilteredItems = [],
        FilterOptions = []
    };
    private string? loadError;
    private AdrStatus? selectedStatus;
    private string searchTerm = string.Empty;
    private AdrBootstrapProposalSet? bootstrapProposalSet;
    private HashSet<string> selectedProposalIds = new(StringComparer.Ordinal);
    private bool isGeneratingProposals;
    private bool isApplyingProposals;
    private string? bootstrapMessage;
    private bool bootstrapMessageIsError;
    private string? uploadStatusMessage;
    private bool uploadStatusIsError;

    /// <summary>
    /// Loads repository ADR data for the requested route parameter.
    /// </summary>
    /// <returns>An asynchronous operation.</returns>
    protected override async Task OnParametersSetAsync()
    {
        loadError = null;
        repository = null;
        repositoryAdrs = [];
        selectedStatus = null;
        searchTerm = string.Empty;
        bootstrapProposalSet = null;
        selectedProposalIds = new HashSet<string>(StringComparer.Ordinal);
        isGeneratingProposals = false;
        isApplyingProposals = false;
        bootstrapMessage = null;
        bootstrapMessageIsError = false;
        uploadStatusMessage = null;
        uploadStatusIsError = false;

        try
        {
            var result = await AdrDocumentService.GetRepositoryWithAdrsAsync(RepositoryId, CancellationToken.None);
            if (result is null)
            {
                loadError = $"Repository '{RepositoryId}' was not found.";
                return;
            }

            repository = result.Value.Repository;
            repositoryAdrs = result.Value.Adrs;
            RebuildProjection();
        }
        catch (InvalidOperationException exception)
        {
            loadError = exception.Message;
        }
        catch (ArgumentException exception)
        {
            loadError = exception.Message;
        }
        catch (FormatException exception)
        {
            loadError = exception.Message;
        }
        catch (IOException exception)
        {
            loadError = exception.Message;
        }
        catch (UnauthorizedAccessException exception)
        {
            loadError = exception.Message;
        }
    }

    /// <summary>
    /// Handles search text changes and refreshes the projected ADR list.
    /// </summary>
    /// <param name="eventArgs">Input event arguments.</param>
    private void HandleSearchInput(ChangeEventArgs eventArgs)
    {
        var inputText = eventArgs.Value?.ToString() ?? string.Empty;
        if (string.Equals(searchTerm, inputText, StringComparison.Ordinal))
        {
            return;
        }

        searchTerm = inputText;
        RebuildProjection();
    }

    /// <summary>
    /// Toggles the active status filter.
    /// </summary>
    /// <param name="status">Selected status.</param>
    private void ToggleStatusFilter(AdrStatus status)
    {
        selectedStatus = selectedStatus == status ? null : status;
        RebuildProjection();
    }

    /// <summary>
    /// Clears the active status filter.
    /// </summary>
    private void ClearStatusFilter()
    {
        selectedStatus = null;
        RebuildProjection();
    }

    /// <summary>
    /// Rebuilds projected list data from ADR source values.
    /// </summary>
    private void RebuildProjection()
    {
        projection = AdrListViewService.BuildList(repositoryAdrs, searchTerm, selectedStatus);
    }

    /// <summary>
    /// Generates AI bootstrap proposals for an empty repository.
    /// </summary>
    /// <returns>An asynchronous operation.</returns>
    private async Task GenerateBootstrapAsync()
    {
        if (repository is null || IsBootstrapActionBusy())
        {
            return;
        }

        isGeneratingProposals = true;
        bootstrapMessage = null;
        bootstrapMessageIsError = false;
        try
        {
            bootstrapProposalSet = await AiBootstrapService.GenerateProposalSetAsync(RepositoryId, CancellationToken.None);
            selectedProposalIds = bootstrapProposalSet.Proposals
                .Select(proposal => proposal.ProposalId)
                .ToHashSet(StringComparer.Ordinal);

            bootstrapMessage = bootstrapProposalSet.Proposals.Count is 0
                ? "No AI proposals were generated from the current repository scan."
                : $"Generated {bootstrapProposalSet.Proposals.Count} proposal(s). Review and accept selected drafts.";
        }
        catch (InvalidOperationException exception)
        {
            bootstrapMessageIsError = true;
            bootstrapMessage = exception.Message;
        }
        catch (ArgumentException exception)
        {
            bootstrapMessageIsError = true;
            bootstrapMessage = exception.Message;
        }
        catch (DirectoryNotFoundException exception)
        {
            bootstrapMessageIsError = true;
            bootstrapMessage = exception.Message;
        }
        catch (IOException exception)
        {
            bootstrapMessageIsError = true;
            bootstrapMessage = exception.Message;
        }
        catch (UnauthorizedAccessException exception)
        {
            bootstrapMessageIsError = true;
            bootstrapMessage = exception.Message;
        }
        finally
        {
            isGeneratingProposals = false;
        }
    }

    /// <summary>
    /// Accepts selected AI proposals and writes proposed ADR markdown files.
    /// </summary>
    /// <returns>An asynchronous operation.</returns>
    private async Task AcceptSelectedProposalsAsync()
    {
        if (repository is null || !CanAcceptSelectedProposals())
        {
            return;
        }

        isApplyingProposals = true;
        bootstrapMessage = null;
        bootstrapMessageIsError = false;

        try
        {
            var result = await AiBootstrapService.AcceptSelectedProposalsAsync(
                RepositoryId,
                bootstrapProposalSet!,
                selectedProposalIds.ToArray(),
                CancellationToken.None);

            bootstrapMessage = $"Created {result.CreatedAdrs.Count} proposed ADR(s). Queued {result.QueuedItems.Count} Git/PR workflow item(s).";
            bootstrapProposalSet = null;
            selectedProposalIds.Clear();
            await ReloadRepositoryAdrsAsync();
        }
        catch (InvalidOperationException exception)
        {
            bootstrapMessageIsError = true;
            bootstrapMessage = exception.Message;
        }
        catch (ArgumentException exception)
        {
            bootstrapMessageIsError = true;
            bootstrapMessage = exception.Message;
        }
        catch (DirectoryNotFoundException exception)
        {
            bootstrapMessageIsError = true;
            bootstrapMessage = exception.Message;
        }
        catch (IOException exception)
        {
            bootstrapMessageIsError = true;
            bootstrapMessage = exception.Message;
        }
        catch (UnauthorizedAccessException exception)
        {
            bootstrapMessageIsError = true;
            bootstrapMessage = exception.Message;
        }
        finally
        {
            isApplyingProposals = false;
        }
    }

    /// <summary>
    /// Toggles proposal selection for review acceptance.
    /// </summary>
    /// <param name="proposalId">Proposal identifier.</param>
    private void ToggleProposalSelection(string proposalId)
    {
        if (IsBootstrapActionBusy())
        {
            return;
        }

        if (selectedProposalIds.Contains(proposalId))
        {
            _ = selectedProposalIds.Remove(proposalId);
            return;
        }

        _ = selectedProposalIds.Add(proposalId);
    }

    /// <summary>
    /// Selects all current proposals.
    /// </summary>
    private void SelectAllProposals()
    {
        if (bootstrapProposalSet is null || IsBootstrapActionBusy())
        {
            return;
        }

        selectedProposalIds = bootstrapProposalSet.Proposals
            .Select(proposal => proposal.ProposalId)
            .ToHashSet(StringComparer.Ordinal);
    }

    /// <summary>
    /// Clears current proposal selection.
    /// </summary>
    private void ClearSelection()
    {
        if (IsBootstrapActionBusy())
        {
            return;
        }

        selectedProposalIds.Clear();
    }

    /// <summary>
    /// Reloads repository ADR values after bootstrap accept operations.
    /// </summary>
    /// <returns>An asynchronous operation.</returns>
    private async Task ReloadRepositoryAdrsAsync()
    {
        var result = await AdrDocumentService.GetRepositoryWithAdrsAsync(RepositoryId, CancellationToken.None);
        if (result is null)
        {
            throw new InvalidOperationException($"Repository '{RepositoryId}' was not found.");
        }

        repository = result.Value.Repository;
        repositoryAdrs = result.Value.Adrs;
        selectedStatus = null;
        searchTerm = string.Empty;
        RebuildProjection();
    }

    /// <summary>
    /// Handles manual inbox uploads from the repository ADR route.
    /// </summary>
    /// <param name="eventArgs">File upload event arguments.</param>
    /// <returns>An asynchronous operation.</returns>
    private async Task HandleInboxUploadAsync(InputFileChangeEventArgs eventArgs)
    {
        if (repository is null)
        {
            uploadStatusIsError = true;
            uploadStatusMessage = "Repository context is unavailable. Reload the page and try again.";
            return;
        }

        uploadStatusIsError = false;
        uploadStatusMessage = null;
        var imported = new List<string>();
        var failures = new List<string>();
        foreach (var upload in eventArgs.GetMultipleFiles())
        {
            try
            {
                await using var uploadStream = upload.OpenReadStream(maxAllowedSize: 1_000_000);
                var markdown = await InboxImportService.ReadUploadMarkdownAsync(uploadStream, 1_000_000, CancellationToken.None);
                var documents = new[] { new RepositoryInboxUploadDocument(upload.Name, markdown) };
                var outcome = await RepositoryInboxUploadService.ImportAsync(repository.Id, documents, CancellationToken.None);
                imported.AddRange(outcome.ImportedAdrs.Select(item => $"ADR-{item.Number:0000}"));
                failures.AddRange(outcome.Failures);
            }
            catch (InvalidOperationException exception)
            {
                failures.Add(exception.Message);
            }
            catch (ArgumentException exception)
            {
                failures.Add(exception.Message);
            }
            catch (IOException exception)
            {
                failures.Add(exception.Message);
            }
            catch (UnauthorizedAccessException exception)
            {
                failures.Add(exception.Message);
            }
        }

        if (imported.Count > 0)
        {
            await ReloadRepositoryAdrsAsync();
        }

        if (failures.Count is 0)
        {
            uploadStatusIsError = false;
            uploadStatusMessage = $"Imported {imported.Count} file(s): {string.Join(", ", imported)}.";
            return;
        }

        uploadStatusIsError = true;
        uploadStatusMessage = imported.Count > 0
            ? $"Imported {imported.Count} file(s), but some files failed: {string.Join(" | ", failures)}"
            : string.Join(" | ", failures);
    }

    /// <summary>
    /// Gets whether bootstrap actions are currently running.
    /// </summary>
    /// <returns><see langword="true"/> when busy; otherwise <see langword="false"/>.</returns>
    private bool IsBootstrapActionBusy()
    {
        return isGeneratingProposals || isApplyingProposals;
    }

    /// <summary>
    /// Gets whether selected proposals can be accepted.
    /// </summary>
    /// <returns><see langword="true"/> when acceptance is allowed.</returns>
    private bool CanAcceptSelectedProposals()
    {
        return bootstrapProposalSet is not null
            && selectedProposalIds.Count > 0
            && !IsBootstrapActionBusy();
    }

    /// <summary>
    /// Gets CSS class for bootstrap status messaging.
    /// </summary>
    /// <returns>Bootstrap status message CSS class.</returns>
    private string GetBootstrapMessageCssClass()
    {
        return bootstrapMessageIsError ? "repo-status repo-status--error" : "repo-status";
    }

    /// <summary>
    /// Gets the page title for metadata.
    /// </summary>
    /// <returns>Page title text.</returns>
    private string GetPageTitle()
    {
        return repository is null ? "Repository ADRs" : $"{repository.DisplayName} ADRs";
    }

    /// <summary>
    /// Gets whether inbox features should be shown for the current repository.
    /// </summary>
    /// <returns><see langword="true"/> when inbox configuration exists.</returns>
    private bool HasInboxConfigured()
    {
        return !string.IsNullOrWhiteSpace(repository?.InboxFolder);
    }

    /// <summary>
    /// Gets inbox path display text for repository context.
    /// </summary>
    /// <returns>Inbox display path.</returns>
    private string GetInboxDisplayPath()
    {
        if (repository is null || string.IsNullOrWhiteSpace(repository.InboxFolder))
        {
            return "disabled";
        }

        return repository.InboxFolder.Replace('\\', '/');
    }
}
