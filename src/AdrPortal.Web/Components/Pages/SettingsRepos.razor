@page "/settings/repos"
@inject IManagedRepositoryStore ManagedRepositoryStore
@inject RepositoryCatalogState RepositoryCatalogState
@inject GlobalLibraryService GlobalLibraryService
@inject IInboxWatcherCoordinator InboxWatcherCoordinator
@inject IManagedRepositoryCheckoutService ManagedRepositoryCheckoutService
@using AdrPortal.Core.Workflows

<PageTitle>Repository settings</PageTitle>

<section class="panel repo-settings">
    <p class="eyebrow">Settings</p>
    <h1>Managed repositories</h1>
    <p class="lead">
        Add, edit, and remove repositories used by ADR Portal. Provide the Git remote URL and optional display name.
        ADR Portal manages checkout, ADR, and inbox paths automatically.
    </p>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <p class="@GetStatusClass()">@statusMessage</p>
    }

    <EditForm EditContext="editContext" OnValidSubmit="SaveAsync">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <fieldset class="repo-settings__fieldset">
            <legend class="repo-settings__legend">@GetEditorHeading()</legend>

            <div class="repo-settings__field">
                <label class="repo-settings__label" for="repo-name">Display name</label>
                <InputText id="repo-name" class="repo-settings__input" @bind-Value="editorModel.DisplayName" />
                <ValidationMessage For="() => editorModel.DisplayName" />
            </div>

            <div class="repo-settings__field">
                <label class="repo-settings__label" for="repo-remote">Git remote URL</label>
                <InputText id="repo-remote" class="repo-settings__input" @bind-Value="editorModel.GitRemoteUrl" />
                <ValidationMessage For="() => editorModel.GitRemoteUrl" />
            </div>

            <div class="repo-settings__field">
                <label class="repo-settings__label">Managed checkout path</label>
                <span class="repo-settings__hint">@GetManagedCheckoutPathPreview()</span>
            </div>

            <div class="repo-settings__field">
                <label class="repo-settings__label">Managed ADR folder</label>
                <span class="repo-settings__hint">/@ManagedRepositoryDefaults.DefaultAdrFolder</span>
            </div>

            <div class="repo-settings__field">
                <label class="repo-settings__label">Managed inbox folder</label>
                <span class="repo-settings__hint">/@ManagedRepositoryDefaults.DefaultInboxFolder</span>
            </div>

            <label class="repo-settings__checkbox">
                <InputCheckbox @bind-Value="editorModel.IsActive" />
                <span>Repository is active</span>
            </label>
        </fieldset>

        <div class="repo-settings__actions">
            <button type="submit" class="repo-settings__button repo-settings__button--primary">
                @GetSaveButtonLabel()
            </button>
            <button type="button" class="repo-settings__button" @onclick="ResetEditor" disabled="@isSaving">
                Reset
            </button>
        </div>
    </EditForm>
</section>

<section class="panel repo-settings repo-settings--list">
    <h2>Configured repositories</h2>

    @if (repositories.Count is 0)
    {
        <p class="shell__hint">No repositories configured.</p>
    }
    else
    {
        <table class="repo-settings__table">
            <thead>
                <tr>
                    <th scope="col">Name</th>
                    <th scope="col">Checkout path</th>
                    <th scope="col">ADR folder</th>
                    <th scope="col">Active</th>
                    <th scope="col">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var repository in repositories)
                {
                    <tr>
                        <td>@repository.DisplayName</td>
                        <td>@repository.RootPath</td>
                        <td>@repository.AdrFolder</td>
                        <td>@(repository.IsActive ? "Yes" : "No")</td>
                        <td class="repo-settings__row-actions">
                            <button type="button" class="repo-settings__button" @onclick="() => BeginEdit(repository)" disabled="@isSaving">
                                Edit
                            </button>
                            <button type="button" class="repo-settings__button repo-settings__button--danger" @onclick="() => DeleteAsync(repository.Id)" disabled="@isSaving">
                                Remove
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

@code
{
    private readonly RepositoryEditorModel editorModel = new();
    private EditContext editContext = default!;
    private IReadOnlyList<ManagedRepository> repositories = [];
    private int? editingRepositoryId;
    private bool isSaving;
    private string? statusMessage;
    private bool statusIsError;

    /// <summary>
    /// Loads repository data and initializes the edit context.
    /// </summary>
    /// <returns>An asynchronous operation.</returns>
    protected override async Task OnInitializedAsync()
    {
        InitializeEditor();
        await LoadRepositoriesAsync(CancellationToken.None);
    }

    /// <summary>
    /// Saves the editor form as either a new repository or an update to an existing repository.
    /// </summary>
    /// <returns>An asynchronous operation.</returns>
    private async Task SaveAsync()
    {
        if (isSaving)
        {
            return;
        }

        isSaving = true;
        statusMessage = null;
        statusIsError = false;

        try
        {
            if (editingRepositoryId is int repositoryId)
            {
                var existingRepository = await GetExistingRepositoryAsync(repositoryId);
                var inferredDefaults = ManagedRepositoryDefaults.InferFromGitRemoteUrl(editorModel.GitRemoteUrl);
                var displayName = ResolveRequiredInput(editorModel.DisplayName);
                var updatedRepository = new ManagedRepository
                {
                    Id = repositoryId,
                    DisplayName = string.IsNullOrWhiteSpace(displayName)
                        ? inferredDefaults.DisplayName
                        : displayName,
                    RootPath = inferredDefaults.RootPath,
                    AdrFolder = ManagedRepositoryDefaults.DefaultAdrFolder,
                    InboxFolder = ManagedRepositoryDefaults.DefaultInboxFolder,
                    GitRemoteUrl = ResolveRequiredInput(editorModel.GitRemoteUrl),
                    IsActive = editorModel.IsActive,
                    CreatedAtUtc = existingRepository.CreatedAtUtc,
                    UpdatedAtUtc = DateTime.UtcNow
                };

                var result = await ManagedRepositoryStore.UpdateAsync(updatedRepository, CancellationToken.None);
                if (result is null)
                {
                    statusIsError = true;
                    statusMessage = "Unable to update repository because it no longer exists.";
                }
                else
                {
                    _ = await ManagedRepositoryCheckoutService.RefreshCheckoutAsync(result, CancellationToken.None);
                    _ = await GlobalLibraryService.ReconcileRepoAsync(result.Id, CancellationToken.None);
                    statusMessage = $"Updated '{result.DisplayName}'.";
                    editingRepositoryId = null;
                    InitializeEditor();
                }
            }
            else
            {
                var createdRepository = ManagedRepositoryDefaults.CreateForAdd(
                    gitRemoteUrl: ResolveRequiredInput(editorModel.GitRemoteUrl),
                    displayNameOverride: editorModel.DisplayName,
                    isActive: editorModel.IsActive);

                var result = await ManagedRepositoryStore.AddAsync(createdRepository, CancellationToken.None);
                _ = await ManagedRepositoryCheckoutService.EnsureLocalCheckoutAsync(result, CancellationToken.None);
                _ = await GlobalLibraryService.ReconcileRepoAsync(result.Id, CancellationToken.None);
                statusMessage = $"Added '{result.DisplayName}'.";
                InitializeEditor();
            }

            await LoadRepositoriesAsync(CancellationToken.None);
            await RepositoryCatalogState.RefreshAsync(CancellationToken.None);
            await InboxWatcherCoordinator.RefreshWatchersAsync(CancellationToken.None);
        }
        catch (InvalidOperationException exception)
        {
            statusIsError = true;
            statusMessage = exception.Message;
        }
        catch (ArgumentException exception)
        {
            statusIsError = true;
            statusMessage = exception.Message;
        }
        catch (FormatException exception)
        {
            statusIsError = true;
            statusMessage = exception.Message;
        }
        catch (IOException exception)
        {
            statusIsError = true;
            statusMessage = exception.Message;
        }
        catch (UnauthorizedAccessException exception)
        {
            statusIsError = true;
            statusMessage = exception.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    /// <summary>
    /// Loads a repository into the form for editing.
    /// </summary>
    /// <param name="repository">Repository selected for editing.</param>
    private void BeginEdit(ManagedRepository repository)
    {
        if (isSaving)
        {
            return;
        }

        editingRepositoryId = repository.Id;
        editorModel.DisplayName = ResolveDisplayNameForEditor(repository);
        editorModel.GitRemoteUrl = repository.GitRemoteUrl ?? string.Empty;
        editorModel.IsActive = repository.IsActive;
        editContext = new EditContext(editorModel);
        statusMessage = $"Editing '{repository.DisplayName}'.";
        statusIsError = false;
    }

    /// <summary>
    /// Deletes a repository by identifier.
    /// </summary>
    /// <param name="repositoryId">Identifier to delete.</param>
    /// <returns>An asynchronous operation.</returns>
    private async Task DeleteAsync(int repositoryId)
    {
        if (isSaving)
        {
            return;
        }

        isSaving = true;
        statusMessage = null;
        statusIsError = false;
        try
        {
            var removed = await ManagedRepositoryStore.DeleteAsync(repositoryId, CancellationToken.None);
            if (!removed)
            {
                statusIsError = true;
                statusMessage = "Unable to remove repository because it was not found.";
                return;
            }

            if (editingRepositoryId == repositoryId)
            {
                editingRepositoryId = null;
                InitializeEditor();
            }

            statusMessage = "Repository removed.";
            await LoadRepositoriesAsync(CancellationToken.None);
            await RepositoryCatalogState.RefreshAsync(CancellationToken.None);
            await InboxWatcherCoordinator.RefreshWatchersAsync(CancellationToken.None);
        }
        finally
        {
            isSaving = false;
        }
    }

    /// <summary>
    /// Resets the editor fields to default values for adding a repository.
    /// </summary>
    private void ResetEditor()
    {
        if (isSaving)
        {
            return;
        }

        editingRepositoryId = null;
        InitializeEditor();
    }

    /// <summary>
    /// Initializes the editor model with add-mode defaults.
    /// </summary>
    private void InitializeEditor()
    {
        editorModel.DisplayName = string.Empty;
        editorModel.GitRemoteUrl = string.Empty;
        editorModel.IsActive = true;

        editContext = new EditContext(editorModel);
    }

    /// <summary>
    /// Loads repositories from persistence.
    /// </summary>
    /// <param name="ct">Cancellation token for the operation.</param>
    /// <returns>An asynchronous operation.</returns>
    private async Task LoadRepositoriesAsync(CancellationToken ct)
    {
        ct.ThrowIfCancellationRequested();
        repositories = await ManagedRepositoryStore.GetAllAsync(ct);
    }

    /// <summary>
    /// Gets the heading shown above the editor form.
    /// </summary>
    /// <returns>Heading text.</returns>
    private string GetEditorHeading()
    {
        return editingRepositoryId is null ? "Add repository" : "Edit repository";
    }

    /// <summary>
    /// Gets the save button text for add or edit mode.
    /// </summary>
    /// <returns>Button label text.</returns>
    private string GetSaveButtonLabel()
    {
        return editingRepositoryId is null ? "Add repository" : "Save changes";
    }

    /// <summary>
    /// Gets CSS class for status messaging based on severity.
    /// </summary>
    /// <returns>Status message CSS class.</returns>
    private string GetStatusClass()
    {
        return statusIsError ? "repo-settings__status repo-settings__status--error" : "repo-settings__status";
    }

    /// <summary>
    /// Normalizes required string inputs.
    /// </summary>
    /// <param name="value">Input value.</param>
    /// <returns>Trimmed input value.</returns>
    private static string ResolveRequiredInput(string? value)
    {
        return value?.Trim() ?? string.Empty;
    }

    /// <summary>
    /// Resolves display-name text for edit mode by suppressing deterministic inferred defaults.
    /// </summary>
    /// <param name="repository">Repository being edited.</param>
    /// <returns>User-provided display name when available; otherwise empty text.</returns>
    private static string ResolveDisplayNameForEditor(ManagedRepository repository)
    {
        var gitRemoteUrl = repository.GitRemoteUrl;
        if (string.IsNullOrWhiteSpace(gitRemoteUrl))
        {
            return repository.DisplayName;
        }

        var inferred = ManagedRepositoryDefaults.InferFromGitRemoteUrl(gitRemoteUrl);
        return string.Equals(repository.DisplayName, inferred.DisplayName, StringComparison.Ordinal)
            ? string.Empty
            : repository.DisplayName;
    }

    /// <summary>
    /// Gets checkout path preview text based on the current remote URL input.
    /// </summary>
    /// <returns>Managed checkout path preview.</returns>
    private string GetManagedCheckoutPathPreview()
    {
        if (string.IsNullOrWhiteSpace(editorModel.GitRemoteUrl))
        {
            return Path.Combine(ManagedRepositoryDefaults.DefaultRepositoriesRootPath, "<owner>", "<repository>");
        }

        try
        {
            var inferred = ManagedRepositoryDefaults.InferFromGitRemoteUrl(editorModel.GitRemoteUrl);
            return inferred.RootPath;
        }
        catch (ArgumentException)
        {
            return Path.Combine(ManagedRepositoryDefaults.DefaultRepositoriesRootPath, "<owner>", "<repository>");
        }
    }

    /// <summary>
    /// Loads repository targeted for update.
    /// </summary>
    /// <param name="repositoryId">Repository identifier.</param>
    /// <returns>Repository when found.</returns>
    private async Task<ManagedRepository> GetExistingRepositoryAsync(int repositoryId)
    {
        var existingRepository = await ManagedRepositoryStore.GetByIdAsync(repositoryId, CancellationToken.None);
        return existingRepository
            ?? throw new InvalidOperationException("Unable to update repository because it no longer exists.");
    }
}
