@page "/"
@inject RepositoryCatalogState RepositoryCatalogState

<PageTitle>ADR Portal</PageTitle>

<section class="panel">
    <p class="eyebrow">Phase 4</p>
    <h1>Repository management is active</h1>
    <p class="lead">
        Configure repositories under <a class="inline-link" href="/settings/repos">Settings → Repositories</a>.
        Entries persist in SQLite via EF Core and automatically appear in the sidebar list.
    </p>
    <dl class="status-grid">
        <div>
            <dt>Runtime</dt>
            <dd>.NET 10</dd>
        </div>
        <div>
            <dt>Orchestration</dt>
            <dd>.NET Aspire</dd>
        </div>
        <div>
            <dt>Persistence</dt>
            <dd>EF Core + SQLite</dd>
        </div>
        <div>
            <dt>Managed repositories</dt>
            <dd>@RepositoryCatalogState.Repositories.Count</dd>
        </div>
    </dl>
</section>
