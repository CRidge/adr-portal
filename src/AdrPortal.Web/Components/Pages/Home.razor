@page "/"
@inject RepositoryCatalogState RepositoryCatalogState

<PageTitle>ADR Portal</PageTitle>

<section class="panel">
    <p class="eyebrow">Phase 7</p>
    <h1>ADR transitions and global registration are active</h1>
    <p class="lead">
        Configure repositories under <a class="inline-link" href="/settings/repos">Settings → Repositories</a>,
        browse ADRs from the sidebar, and use detail-page lifecycle actions to accept, reject, supersede, and deprecate ADRs.
    </p>
    <dl class="status-grid">
        <div>
            <dt>Runtime</dt>
            <dd>.NET 10</dd>
        </div>
        <div>
            <dt>Orchestration</dt>
            <dd>.NET Aspire</dd>
        </div>
        <div>
            <dt>Persistence</dt>
            <dd>EF Core + SQLite</dd>
        </div>
        <div>
            <dt>Managed repositories</dt>
            <dd>@RepositoryCatalogState.Repositories.Count</dd>
        </div>
    </dl>
</section>
