@page "/"
@inject RepositoryCatalogState RepositoryCatalogState

<PageTitle>ADR Portal</PageTitle>

<section class="panel">
    <p class="eyebrow">Phase 8</p>
    <h1>Global ADR library and sync workflows are active</h1>
    <p class="lead">
        Configure repositories under <a class="inline-link" href="/settings/repos">Settings → Repositories</a>,
        review <a class="inline-link" href="/global">Global ADR library</a> routes, and use repository detail sync actions to propose or apply template updates.
    </p>
    <dl class="status-grid">
        <div>
            <dt>Runtime</dt>
            <dd>.NET 10</dd>
        </div>
        <div>
            <dt>Orchestration</dt>
            <dd>.NET Aspire</dd>
        </div>
        <div>
            <dt>Persistence</dt>
            <dd>EF Core + SQLite</dd>
        </div>
        <div>
            <dt>Managed repositories</dt>
            <dd>@RepositoryCatalogState.Repositories.Count</dd>
        </div>
        <div>
            <dt>Pending global sync</dt>
            <dd>@RepositoryCatalogState.DashboardPendingCount</dd>
        </div>
    </dl>
    <p class="lead">
        Next actions: open <a class="inline-link" href="/global">/global</a> for library-level counts,
        then drill into <code>/global/{globalId}</code> for version history, baseline diff, and instance update scaffolding.
    </p>
</section>
