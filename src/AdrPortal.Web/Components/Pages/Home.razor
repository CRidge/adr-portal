@page "/"

<PageTitle>ADR Portal</PageTitle>

<section class="panel">
    <p class="eyebrow">Phase 1</p>
    <h1>ADR Portal foundation is ready</h1>
    <p class="lead">
        This shell verifies the core application scaffold: Aspire startup, EF Core persistence wiring,
        and a minimal Blazor layout with custom styling.
    </p>
    <dl class="status-grid">
        <div>
            <dt>Runtime</dt>
            <dd>.NET 10</dd>
        </div>
        <div>
            <dt>Orchestration</dt>
            <dd>.NET Aspire</dd>
        </div>
        <div>
            <dt>Persistence</dt>
            <dd>EF Core + SQLite</dd>
        </div>
    </dl>
</section>
