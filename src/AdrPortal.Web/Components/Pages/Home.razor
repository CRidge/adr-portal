@page "/"
@inject RepositoryCatalogState RepositoryCatalogState

<PageTitle>ADR Portal</PageTitle>

<section class="panel">
    <p class="eyebrow">Workspace overview</p>
    <h1>Architecture decision workflow and template sync</h1>
    <p class="lead">
        Configure repositories under <a class="inline-link" href="/settings/repos">Settings → Repositories</a>,
        author and review ADRs in each repository, and coordinate shared templates through the
        <a class="inline-link" href="/global">Global ADR library</a>.
    </p>
    <dl class="status-grid">
        <div>
            <dt>Runtime</dt>
            <dd>.NET 10</dd>
        </div>
        <div>
            <dt>Orchestration</dt>
            <dd>.NET Aspire</dd>
        </div>
        <div>
            <dt>Persistence</dt>
            <dd>EF Core + SQLite</dd>
        </div>
        <div>
            <dt>Managed repositories</dt>
            <dd>@RepositoryCatalogState.Repositories.Count</dd>
        </div>
        <div>
            <dt>Pending global sync</dt>
            <dd>@RepositoryCatalogState.DashboardPendingCount</dd>
        </div>
    </dl>
    <p class="lead">
        Suggested flow: draft or update an ADR, run in-editor AI evaluation to compare options,
        then open <a class="inline-link" href="/compare">/compare</a> to import related ADRs across repositories.
        Use <a class="inline-link" href="/global">/global</a> to review library proposals and apply template updates to instances.
    </p>
</section>
