@page "/"
@inject RepositoryCatalogState RepositoryCatalogState

<PageTitle>ADR Portal</PageTitle>

<section class="panel">
    <p class="eyebrow">Phase 13</p>
    <h1>Source-to-target ADR comparison and import workflows are active</h1>
    <p class="lead">
        Configure repositories under <a class="inline-link" href="/settings/repos">Settings → Repositories</a>,
        compare catalogs under <a class="inline-link" href="/compare">/compare</a>, and review
        <a class="inline-link" href="/global">Global ADR library</a> mappings.
    </p>
    <dl class="status-grid">
        <div>
            <dt>Runtime</dt>
            <dd>.NET 10</dd>
        </div>
        <div>
            <dt>Orchestration</dt>
            <dd>.NET Aspire</dd>
        </div>
        <div>
            <dt>Persistence</dt>
            <dd>EF Core + SQLite</dd>
        </div>
        <div>
            <dt>Managed repositories</dt>
            <dd>@RepositoryCatalogState.Repositories.Count</dd>
        </div>
        <div>
            <dt>Pending global sync</dt>
            <dd>@RepositoryCatalogState.DashboardPendingCount</dd>
        </div>
    </dl>
    <p class="lead">
        Next actions: open <a class="inline-link" href="/compare">/compare</a> to select source and target repositories,
        rank source ADR relevance against the target catalog, select import rows, and create proposed ADR drafts.
    </p>
</section>
